---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Divider from '@/components/ui/Divider.astro';
import Pause from '@/components/ui/Pause.astro';
import TrustBar from '@/components/ui/TrustBar.astro';
import RecedingShoreline from '@/components/sections/RecedingShoreline.astro';
import RevealHeadline from '@/components/ui/RevealHeadline.astro';
import FAQAccordion from '@/components/islands/FAQAccordion';
import ServiceShowcase from '@/components/sections/ServiceShowcase.astro';
import { FAQS } from '@/data/faq';
import { SERVICE_AREA } from '@/data/serviceArea';

const featurableId = import.meta.env.FEATURABLE_WIDGET_ID;

const faqSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://bayshine.net/#business',
      name: 'BayShine Detailing',
      description:
        'Mobile auto detailing serving Pasco County and North Hillsborough County, FL.',
      telephone: '+18133245522',
      url: 'https://bayshine.net',
      priceRange: '$$',
      areaServed: SERVICE_AREA.map(z => ({
        '@type': 'PostalAddress',
        postalCode: z.code,
        addressRegion: 'FL',
        addressCountry: 'US',
      })),
    },
    {
      '@type': 'FAQPage',
      mainEntity: FAQS.map(f => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
  ],
};
---
<BaseLayout
  title="Mobile Auto Detailing | Pasco County"
  description="Mobile auto detailing in Pasco County and North Hillsborough, FL. Full detail, exterior, ceramic coating, and fleet programs."
  schema={faqSchema}
>

  <!-- ── HERO ───────────────────────────────────────────────── -->
  <section class="noise-overlay min-h-[90vh] flex flex-col justify-center items-center px-4 pt-[10vh] pb-20">
    <div class="container mx-auto max-w-3xl text-center relative">
      <h1 class="hero-headline headline-breathing font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-bay-white leading-[1.08] mb-10" data-reveal style="text-shadow: 0 2px 24px rgba(15,27,45,0.7);">
        <RevealHeadline
          primary="Mobile auto detailing."
          accent="Pasco County and North Hillsborough."
        />
      </h1>

      <div class="flex flex-wrap gap-8 justify-center">
        <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
          Book Now
        </Button>
        <Button href="/quote" variant="secondary" class="text-base px-8 py-3.5">
          Get a Quote
        </Button>
      </div>
    </div>
  </section>

  <RecedingShoreline />

  <!-- ── TRUST BAR ──────────────────────────────────────────── -->
  <TrustBar />

  <Divider class="my-0" />

  <!-- ── SPLIT SECTION: Private / Fleet / Apartments ──────── -->
  <section class="section-bevel py-20 px-4">
    <div class="container mx-auto max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 md:gap-px bg-bay-slate/20 rounded-sm overflow-hidden">

        <!-- Private owner panel -->
        <div class="reveal bg-bay-navy p-10 md:p-12">
          <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">Private Owners</p>
          <h2 class="font-display font-bold text-3xl text-bay-white mb-4 leading-tight">
            Your daily driver.<br />Done right.
          </h2>
          <p class="text-bay-slate leading-relaxed mb-6">
            Panel-by-panel, in correct sequence, on your schedule. The Standing Detail
            program keeps your vehicle in maintained condition year-round.
          </p>
          <Button href="/full-detail" variant="secondary">
            Full Detail →
          </Button>
        </div>

        <!-- Fleet / B2B panel -->
        <div class="reveal bg-bay-deep p-10 md:p-12">
          <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">Fleet &amp; B2B</p>
          <p class="font-display text-[10px] font-medium text-bay-slate/60 uppercase tracking-widest mb-1">Starting as low as</p>
          <h2 class="font-display font-bold text-3xl text-bay-white mb-4 leading-tight">
            $1.10 per unit.<br />Standing schedule.
          </h2>
          <p class="text-bay-slate leading-relaxed mb-6">
            Lot maintenance for 30 to 300+ vehicles. Walk the lot, set the schedule,
            receive a monthly invoice. Throughput is the metric.
          </p>
          <Button href="/fleet" variant="secondary">
            Fleet Programs →
          </Button>
        </div>

        <!-- Apartments panel -->
        <div class="reveal bg-bay-deep/60 p-10 md:p-12">
          <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">Property Programs</p>
          <h2 class="font-display font-bold text-3xl text-bay-white mb-4 leading-tight">
            On-property.<br />No overhead.
          </h2>
          <p class="text-bay-slate leading-relaxed mb-6">
            Resident detailing program for apartment communities. Residents enroll directly:
            the property adds a premium amenity at zero cost.
          </p>
          <Button href="/apartments" variant="secondary">
            Apartment Programs →
          </Button>
        </div>

      </div>
    </div>
  </section>

  <Divider />

  <!-- ── SERVICES SHOWCASE ────────────────────────────────── -->
  <ServiceShowcase />

  <Divider />

  <!-- ── STANDING DETAIL PROGRAM ────────────────────────────── -->
  <section class="noise-overlay section-bevel bg-bay-deep py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal">
        <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">The Headline Service</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white mb-6 leading-tight">
          The BayShine Standing Detail.
        </h2>

        <p class="text-bay-bone text-lg leading-relaxed mb-8 max-w-2xl">
          A <span class="font-mono text-bay-gold">6-week</span> recurring program. The first visit establishes the baseline: full detail
          at the standard rate. Every visit after that is a maintenance detail: shorter
          because the vehicle stays clean between appointments.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
          {[
            {
              label: 'Priority Slot',
              desc: 'Your recurring time is held. No competing for availability.',
            },
            {
              label: 'Locked Rate',
              desc: 'The price you start at is the price you keep.',
            },
            {
              label: 'Cancel Anytime',
              desc: 'No contracts. No cancellation fee. No pressure.',
            },
          ].map(item => (
            <div class="border-l-2 border-bay-gold pl-5">
              <p class="font-semibold text-bay-white text-sm mb-1">{item.label}</p>
              <p class="text-bay-slate text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
          Start the Standing Detail
        </Button>
      </div>
    </div>
  </section>

  <Pause />

  <!-- ── REVIEWS — conditional Featurable embed ────────────── -->
  {featurableId && (
    <>
      <section class="section-bevel py-20 px-4">
        <div class="container mx-auto max-w-5xl">
          <div class="reveal mb-8">
            <h2 class="font-display font-bold text-3xl text-bay-white mb-3">What clients say</h2>
          </div>
          <div class="featurable-widget" data-widget-id={featurableId}></div>
          <script src="https://cdn.featurable.com/assets/widget/v1/featurable-widget.min.js" async is:inline></script>
        </div>
      </section>
      <Divider />
    </>
  )}

  <!-- ── FAQ ───────────────────────────────────────────────── -->
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-2xl">
      <div class="reveal mb-8">
        <h2 class="font-display font-bold text-3xl text-bay-white mb-3">Questions</h2>
      </div>
      <FAQAccordion faqs={FAQS} client:visible />
    </div>
  </section>

  <Pause />

  <!-- ── FINAL CTA ──────────────────────────────────────────── -->
  <section class="noise-overlay bg-bay-deep py-20 px-4">
    <div class="container mx-auto max-w-2xl text-center">
      <div class="reveal">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white mb-4">
          Ready to schedule?
        </h2>
        <p class="text-bay-slate mb-8">
          Book online or call. We respond within 2 hours.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
            Book Now
          </Button>
          <Button href="/quote" variant="secondary" class="text-base px-8 py-3.5">
            Get a Quote
          </Button>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
