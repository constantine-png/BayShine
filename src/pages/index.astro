---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Divider from '@/components/ui/Divider.astro';
import Pause from '@/components/ui/Pause.astro';
import TrustBar from '@/components/ui/TrustBar.astro';
import HeroToTrustTransition from '@/components/sections/HeroToTrustTransition.astro';
import CustomerTypeStack from '@/components/sections/CustomerTypeStack.astro';
import ServiceRevealSequence from '@/components/sections/ServiceRevealSequence.astro';
import RevealHeadline from '@/components/ui/RevealHeadline.astro';
import FAQAccordion from '@/components/islands/FAQAccordion';
import { FAQS } from '@/data/faq';
import { SERVICE_AREA } from '@/data/serviceArea';

const featurableId = import.meta.env.FEATURABLE_WIDGET_ID;

const uniqueCities = [...new Set(SERVICE_AREA.map(z => z.city))];

const faqSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['LocalBusiness', 'AutoWash'],
      '@id': 'https://bayshine.net/#business',
      name: 'BayShine Detailing',
      description:
        'Mobile auto detailing serving Land O\' Lakes, Pasco County, and North Hillsborough County, FL.',
      telephone: '+18133245522',
      address: {
        '@type': 'PostalAddress',
        addressLocality: "Land O' Lakes",
        addressRegion: 'FL',
        postalCode: '34638',
        addressCountry: 'US',
      },
      url: 'https://bayshine.net',
      priceRange: '$$',
      // FOLLOWUP: src/pages/index.astro — Add sameAs array when social/GBP profiles are confirmed.
      // Format: sameAs: ['https://maps.google.com/?cid=YOUR_CID', 'https://www.facebook.com/bayshinedetailing', 'https://www.instagram.com/bayshinedetailing']
      // Omitting the property entirely is correct until real URLs are available — empty array emits useless JSON-LD.
      areaServed: uniqueCities.map(city => ({
        '@type': 'City',
        name: city,
      })),
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
          opens: '08:00',
          closes: '20:00',
        },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: FAQS.map(f => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
  ],
};
---
<BaseLayout
  title="Mobile Auto Detailing | Pasco County"
  description="Mobile auto detailing in Pasco County and North Hillsborough, FL. Full detail, exterior, ceramic coating, and fleet programs."
  schema={faqSchema}
>

  <!-- ── HERO ───────────────────────────────────────────────── -->
  <section class="noise-overlay min-h-[90vh] flex flex-col justify-center items-center px-4 pt-[10vh] pb-20">
    <div class="container mx-auto max-w-3xl text-center relative">
      <h1 class="hero-headline headline-breathing font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-bay-white leading-[1.08] mb-10" data-reveal style="text-shadow: 0 2px 24px rgba(15,27,45,0.7);">
        <RevealHeadline
          primary="Mobile auto detailing."
          accent="Pasco County and North Hillsborough."
        />
      </h1>

      <div class="flex flex-wrap gap-8 justify-center">
        <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
          Book Now
        </Button>
        <Button href="/quote" variant="secondary" class="text-base px-8 py-3.5">
          Get a Quote
        </Button>
      </div>
    </div>
  </section>

  <HeroToTrustTransition />

  <!-- ── TRUST BAR ──────────────────────────────────────────── -->
  <TrustBar />

  <Divider class="my-0" />

  <!-- ── CUSTOMER TYPE STACK: Private / Fleet / Apartments ─── -->
  <CustomerTypeStack />

  <Divider />

  <!-- ── SERVICE REVEAL SEQUENCE ───────────────────────────── -->
  <ServiceRevealSequence />

  <Divider />

  <!-- ── LAND O' LAKES NEIGHBORHOOD CALLOUT ───────────────── -->
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-4xl reveal">
      <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-3">Home Base</p>
      <h2 class="font-display font-bold text-2xl text-bay-white mb-4 leading-tight">
        Land O' Lakes is where we operate from.
      </h2>
      <p class="text-bay-slate text-base leading-relaxed mb-6 max-w-2xl">
        Fastest response times, deepest coverage. We serve Bexley, Connerton, Lake Padgett Estates, Wilderness Lake Preserve, and Lakeshore Ranch — on-site, no drop-off.
      </p>
      <a
        href="/land-o-lakes"
        class="inline-block text-bay-gold font-display font-semibold text-sm hover:text-[#d9bc79] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold rounded-sm underline underline-offset-4"
      >
        Land O' Lakes neighborhood coverage &rarr;
      </a>
    </div>
  </section>

  <Divider />

  <!-- ── STANDING DETAIL PROGRAM ────────────────────────────── -->
  <section id="standing-detail" class="noise-overlay section-bevel bg-bay-deep py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal">
        <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">The Headline Service</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white mb-6 leading-tight">
          The BayShine Standing Detail.
        </h2>

        <p class="text-bay-bone text-lg leading-relaxed mb-8 max-w-2xl">
          A <span class="font-mono text-bay-gold">6-week</span> recurring program. The first visit establishes the baseline: full detail
          at the standard rate. Every visit after that is a maintenance detail: shorter
          because the vehicle stays clean between appointments. <a href="/standing-detail" class="text-bay-gold hover:text-[#d9bc79] underline underline-offset-2 transition-colors">How the program works</a>.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
          {[
            {
              label: 'Priority Slot',
              desc: 'Your recurring time is held. No competing for availability.',
            },
            {
              label: 'Locked Rate',
              desc: 'The price you start at is the price you keep.',
            },
            {
              label: 'Cancel Anytime',
              desc: 'No contracts. No cancellation fee. No pressure.',
            },
          ].map(item => (
            <div class="border-l-2 border-bay-gold pl-5">
              <p class="font-semibold text-bay-white text-sm mb-1">{item.label}</p>
              <p class="text-bay-slate text-sm">{item.desc}</p>
            </div>
          ))}
        </div>

        <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
          Start the Standing Detail
        </Button>
      </div>
    </div>
  </section>

  <Pause />

  <!-- ── REVIEWS — conditional Featurable embed ────────────── -->
  {featurableId && (
    <>
      <section class="section-bevel py-20 px-4">
        <div class="container mx-auto max-w-5xl">
          <div class="reveal mb-8">
            <h2 class="font-display font-bold text-3xl text-bay-white mb-3">What clients say</h2>
          </div>
          <div class="featurable-widget" data-widget-id={featurableId}></div>
          <script src="https://cdn.featurable.com/assets/widget/v1/featurable-widget.min.js" async is:inline></script>
        </div>
      </section>
      <Divider />
    </>
  )}

  <!-- ── FAQ ───────────────────────────────────────────────── -->
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-2xl">
      <div class="reveal mb-8">
        <h2 class="font-display font-bold text-3xl text-bay-white mb-3">Questions</h2>
      </div>
      <FAQAccordion faqs={FAQS} client:visible />
    </div>
  </section>

  <Pause />

  <!-- ── FINAL CTA ──────────────────────────────────────────── -->
  <section class="noise-overlay bg-bay-deep py-20 px-4">
    <div class="container mx-auto max-w-2xl text-center">
      <div class="reveal">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white mb-4">
          Ready to schedule?
        </h2>
        <p class="text-bay-slate mb-8">
          Book online or call. We respond within 2 hours.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
            Book Now
          </Button>
          <Button href="/quote" variant="secondary" class="text-base px-8 py-3.5">
            Get a Quote
          </Button>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
