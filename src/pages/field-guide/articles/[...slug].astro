---
// Field Guide article renderer — TechArticle schema, severity badge, breadcrumb to /field-guide.
// Mirrors blog/[...slug].astro layout; diverges in schema type, breadcrumb, and category badge logic.
export const prerender = false;

import { getEntry } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import EmailCapture from '@/components/ui/EmailCapture.astro';

const { slug } = Astro.params;
const post = slug
  ? await getEntry('fieldGuideScenarios', Array.isArray(slug) ? slug.join('/') : slug)
  : undefined;

if (!post) {
  return Astro.redirect('/field-guide', 302);
}

const isPreview = Astro.cookies.get('bayshine-preview')?.value === '1';

if (post.data.draft && !isPreview) {
  return Astro.redirect('/field-guide', 302);
}

const { Content } = await post.render();

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Severity display config — shown as a badge in the header
const severityConfig: Record<string, { label: string; class: string }> = {
  'quick-fix': { label: 'Quick Fix',  class: 'bg-bay-gold/15 text-bay-gold' },
  'moderate':  { label: 'Moderate',   class: 'bg-orange-100 text-orange-700' },
  'advanced':  { label: 'Advanced',   class: 'bg-red-100 text-red-700' },
};

// GEO + category keyword set for schema and meta
const categoryKeywords: Record<string, string[]> = {
  'paint':          ['paint correction', 'clear coat', 'paint protection'],
  'interior':       ['interior detailing', 'leather care', 'upholstery'],
  'glass':          ['automotive glass', 'windshield cleaning', 'streak free glass'],
  'wheels':         ['wheel cleaning', 'brake dust removal', 'wheel detailing'],
  'trim':           ['trim restoration', 'plastic trim', 'interior trim'],
  'coating':        ['ceramic coating', 'paint sealant', 'surface protection'],
  'contamination':  ['paint decontamination', 'iron fallout', 'clay bar'],
  'correction':     ['paint correction', 'polish', 'compound'],
  'tools':          ['detailing tools', 'microfiber', 'detailing supplies'],
  'general':        [],
};

const catKws = categoryKeywords[post.data.category] ?? [];
const articleKeywords = [
  ...(post.data.keywords ?? catKws),
  'mobile auto detailing',
  'Pasco County FL',
  'North Hillsborough FL',
  'BayShine Detailing',
].join(', ');

const articleUrl = `https://bayshine.net/field-guide/articles/${post.slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      '@id': `${articleUrl}#article`,
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.pubDate.toISOString(),
      inLanguage: 'en-US',
      url: articleUrl,
      articleSection: post.data.category,
      keywords: articleKeywords,
      // @id-only reference — inline @type/name/url alongside @id causes parsers to merge
      // unexpected properties onto the canonical entity node. Use @id reference only.
      author: { '@id': 'https://bayshine.net/#business' },
      publisher: { '@id': 'https://bayshine.net/#business' },
      mainEntityOfPage: articleUrl,
      isPartOf: {
        '@type': 'WebPage',
        '@id': 'https://bayshine.net/field-guide',
        name: 'BayShine Field Guide',
        url: 'https://bayshine.net/field-guide',
      },
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: ['h1', '#article-description', '.blog-prose > p:first-child'],
      },
      mentions: [
        { '@type': 'AdministrativeArea', name: 'Pasco County', containedInPlace: { '@type': 'State', name: 'Florida' } },
        { '@type': 'AdministrativeArea', name: 'North Hillsborough County', containedInPlace: { '@type': 'State', name: 'Florida' } },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',        item: 'https://bayshine.net' },
        { '@type': 'ListItem', position: 2, name: 'Field Guide', item: 'https://bayshine.net/field-guide' },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: articleUrl },
      ],
    },
  ],
};

const severity = post.data.severity ? severityConfig[post.data.severity] : undefined;
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  schema={articleSchema}
  bodyClass="blog-body"
  ogType="article"
  articlePublishedTime={post.data.pubDate.toISOString()}
  articleSection={post.data.category}
  keywords={articleKeywords}
>
  {post.data.draft && isPreview && (
    <div class="bg-orange-100 border-b border-orange-200 px-4 py-2">
      <p class="container mx-auto max-w-2xl text-xs text-orange-800 font-semibold font-display">
        Draft: not publicly visible.
        <a href="/api/preview?clear=1" class="underline ml-2">Exit preview</a>
      </p>
    </div>
  )}

  <article class="bg-bay-paper">
    <!-- Article header -->
    <header class="py-16 px-4 border-b border-bay-ink/10">
      <div class="container mx-auto max-w-2xl">
        <div class="flex items-center gap-4 text-xs mb-6">
          <a
            href="/field-guide"
            class="font-display text-bay-ink/50 hover:text-bay-navy transition-colors uppercase tracking-wider text-[10px] font-bold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold rounded-sm"
          >
            &larr; Field Guide
          </a>
          <span class="text-bay-ink/30">·</span>
          <span class="font-display text-bay-gold text-[10px] font-bold uppercase tracking-widest">
            {post.data.category}
          </span>
          {severity && (
            <>
              <span class="text-bay-ink/30">·</span>
              <span class={`font-display text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-sm ${severity.class}`}>
                {severity.label}
              </span>
            </>
          )}
        </div>

        <h1 class="font-display font-bold text-3xl sm:text-4xl text-bay-navy mb-5 leading-tight tracking-tight">
          {post.data.title}
        </h1>

        <p id="article-description" class="font-serif text-bay-ink/60 text-lg leading-relaxed mb-6">
          {post.data.description}
        </p>

        <div class="flex items-center gap-4 text-xs text-bay-ink/40 font-display uppercase tracking-wider">
          <span>BayShine Detailing</span>
          <span>·</span>
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <span>·</span>
          <span>{post.data.readTime} min read</span>
        </div>
      </div>
    </header>

    <!-- Article body -->
    <div class="py-12 px-4">
      <div class="container mx-auto max-w-2xl">
        <div class="blog-prose">
          <Content />
        </div>
      </div>
    </div>

    <div class="px-4">
      <div class="container mx-auto max-w-2xl">
        <hr class="border-none h-px bg-bay-ink/10 my-0" />
      </div>
    </div>

    <!-- Booking CTA -->
    <div class="py-12 px-4 bg-bay-navy/40 border-t border-bay-ink/10">
      <div class="container mx-auto max-w-2xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <p class="font-display font-semibold text-bay-white text-base">
          Ready to book?
        </p>
        <Button href="/contact" variant="primary">
          Schedule a Detail
        </Button>
      </div>
    </div>

    <!-- Inline email capture -->
    <div class="py-12 px-4 bg-bay-paper">
      <div class="container mx-auto max-w-2xl">
        <EmailCapture
          label="Get the next one."
          source={`field-guide-${post.slug}`}
        />
      </div>
    </div>
  </article>
</BaseLayout>
