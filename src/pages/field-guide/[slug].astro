---
export const prerender = false;

import FieldGuideLayout from '@/components/layout/FieldGuideLayout.astro';
import Divider from '@/components/ui/Divider.astro';
import { getScenario, getRelatedScenarios, getScenarioProducts } from '@/lib/field-guide-db';
import ProductCard from '@/components/field-guide/ProductCard.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/field-guide');

const scenario = await getScenario(slug);
if (!scenario) return Astro.redirect('/field-guide');

const related = await getRelatedScenarios(slug, scenario.category_slug);
const products = await getScenarioProducts(slug);

const SEVERITY_LABEL = {
  'quick-fix': 'Quick Fix',
  'moderate':  'Moderate',
  'advanced':  'Advanced',
} as const;

const SEVERITY_COLOR = {
  'quick-fix': '#4caf50',
  'moderate':  '#c9a961',
  'advanced':  '#ef5350',
} as const;

const sev = scenario.severity as keyof typeof SEVERITY_LABEL;

const scenarioUrl = `https://bayshine.net/field-guide/${slug}`;
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      '@id': `${scenarioUrl}#article`,
      headline: scenario.title,
      description: scenario.problem.slice(0, 200),
      // @id-only references — avoids duplicate/competing Organization nodes in the graph
      author: { '@id': 'https://bayshine.net/#business' },
      publisher: { '@id': 'https://bayshine.net/#business' },
      mainEntityOfPage: scenarioUrl,
      url: scenarioUrl,
      inLanguage: 'en-US',
      // published_at may be null for DB rows without an explicit date — omit rather than emit undefined
      ...(scenario.published_at ? { datePublished: scenario.published_at.slice(0, 10) } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',        item: 'https://bayshine.net' },
        { '@type': 'ListItem', position: 2, name: 'Field Guide', item: 'https://bayshine.net/field-guide' },
        { '@type': 'ListItem', position: 3, name: scenario.title, item: scenarioUrl },
      ],
    },
  ],
};
---

<FieldGuideLayout
  title={`${scenario.title} — BayShine Field Guide`}
  description={scenario.problem.slice(0, 155)}
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav
    aria-label="Breadcrumb"
    style="padding: 28px 24px 0; max-width: 820px; margin: 0 auto;"
  >
    <p style="font-family: var(--font-family-mono); font-size: 11px; color: var(--color-guide-text-muted); letter-spacing: 0.05em; margin: 0;">
      <a href="/field-guide" style="color: var(--color-guide-accent); text-decoration: none;">Field Guide</a>
      {' '}·{' '}
      <span>{scenario.category_name}</span>
      {' '}·{' '}
      <span style="color: var(--color-guide-heading);">{SEVERITY_LABEL[sev]}</span>
    </p>
  </nav>

  <!-- Scenario header -->
  <header style="padding: 28px 24px 40px; max-width: 820px; margin: 0 auto;">
    <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 18px; flex-wrap: wrap;">
      <span
        style="font-family: var(--font-family-mono); font-size: 10px; letter-spacing: 0.1em;
               color: var(--color-guide-text-muted); background: var(--color-guide-surface);
               padding: 3px 9px; border: 1px solid var(--color-guide-border);"
      >
        {scenario.category_name}
      </span>
      <span
        style={`font-family: var(--font-family-mono); font-size: 10px; letter-spacing: 0.1em;
                color: ${SEVERITY_COLOR[sev]};`}
      >
        {SEVERITY_LABEL[sev]}
      </span>
    </div>

    <h1
      style="font-family: var(--font-family-display); font-weight: 700;
             font-size: clamp(24px, 4vw, 38px); color: var(--color-guide-heading);
             margin: 0; line-height: 1.18; letter-spacing: 0.01em;"
    >
      {scenario.title}
    </h1>
  </header>

  <Divider />

  <!-- The Problem -->
  <section style="padding: 48px 24px 40px; max-width: 820px; margin: 0 auto;">
    <p
      style="font-family: var(--font-family-display); font-size: 10px; font-weight: 700;
             text-transform: uppercase; letter-spacing: 0.2em;
             color: var(--color-guide-accent); margin: 0 0 16px;"
    >
      The Problem
    </p>
    <p style="font-size: 17px; color: var(--color-guide-text); line-height: 1.75; max-width: 660px; margin: 0;">
      {scenario.problem}
    </p>
  </section>

  <Divider />

  <!-- The Approach -->
  <section style="padding: 48px 24px 40px; max-width: 820px; margin: 0 auto;">
    <p
      style="font-family: var(--font-family-display); font-size: 10px; font-weight: 700;
             text-transform: uppercase; letter-spacing: 0.2em;
             color: var(--color-guide-accent); margin: 0 0 16px;"
    >
      The Approach
    </p>
    <p style="font-size: 16px; color: var(--color-guide-text); line-height: 1.8; max-width: 660px; margin: 0;">
      {scenario.synopsis}
    </p>
  </section>

  <Divider />

  <!-- Products for this scenario -->
  <section style="padding: 48px 24px 40px; max-width: 820px; margin: 0 auto;">
    <p
      style="font-family: var(--font-family-display); font-size: 10px; font-weight: 700;
             text-transform: uppercase; letter-spacing: 0.2em;
             color: var(--color-guide-accent); margin: 0 0 16px;"
    >
      Products for This Scenario
    </p>

    {products.length > 0 ? (
      <div style="display: flex; flex-direction: column; gap: 10px;">
        {products.map(p => <ProductCard product={p} />)}
        <p style="font-size: 11px; color: var(--color-guide-text-muted); margin: 12px 0 0; line-height: 1.5; opacity: 0.7;">
          BayShine earns a commission on qualifying purchases at no cost to you. We only list products we use on real jobs.
        </p>
      </div>
    ) : (
      <div
        style="border: 1px solid var(--color-guide-border); border-left: 3px solid var(--color-guide-border);
               padding: 20px 22px; background: var(--color-guide-surface);"
      >
        <p style="font-size: 14px; color: var(--color-guide-text-muted); margin: 0 0 10px; line-height: 1.6;">
          Product recommendations will be added here when a matching affiliate relationship is in place.
          We only list products we've used and evaluated on real jobs.
        </p>
        <p style="font-size: 11px; color: var(--color-guide-text-muted); margin: 0; opacity: 0.65; line-height: 1.5;">
          This guide may contain affiliate links. BayShine earns a commission on qualifying purchases at no cost to you.
        </p>
      </div>
    )}
  </section>

  <!-- Related scenarios in same category -->
  {related.length > 0 && (
    <>
      <Divider />
      <section style="padding: 48px 24px 48px; max-width: 820px; margin: 0 auto;">
        <p
          style="font-family: var(--font-family-display); font-size: 10px; font-weight: 700;
                 text-transform: uppercase; letter-spacing: 0.2em;
                 color: var(--color-guide-accent); margin: 0 0 16px;"
        >
          More in {scenario.category_name}
        </p>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          {related.map(r => {
            const rsev = r.severity as keyof typeof SEVERITY_LABEL;
            return (
              <a
                href={`/field-guide/${r.slug}`}
                style="display: block; padding: 16px 18px; background: var(--color-guide-surface);
                       border: 1px solid var(--color-guide-border); text-decoration: none;"
              >
                <p style="font-family: var(--font-family-display); font-size: 14px; font-weight: 600;
                           color: var(--color-guide-heading); margin: 0 0 5px; line-height: 1.3;">
                  {r.title}
                </p>
                <span style={`font-family: var(--font-family-mono); font-size: 10px; letter-spacing: 0.08em; color: ${SEVERITY_COLOR[rsev]};`}>
                  {SEVERITY_LABEL[rsev]}
                </span>
              </a>
            );
          })}
        </div>
      </section>
    </>
  )}

  <Divider />

  <!-- Back to search -->
  <section style="padding: 40px 24px 80px; max-width: 820px; margin: 0 auto; text-align: center;">
    <a
      href="/field-guide"
      style="font-family: var(--font-family-display); font-size: 12px; font-weight: 700;
             letter-spacing: 0.1em; text-transform: uppercase;
             color: var(--color-guide-accent); text-decoration: none;
             border-bottom: 1px solid var(--color-guide-accent-dim); padding-bottom: 2px;"
    >
      ← Back to Field Guide
    </a>
  </section>

</FieldGuideLayout>
