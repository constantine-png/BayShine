---
// Field Guide admin — query analytics dashboard.
// Auth: SHA-256 hash of ADMIN_PASSWORD stored as an httpOnly cookie.
// Not production-grade auth — one-operator tool. See TODO.md for upgrade path.
// noindex, nofollow — never link to this page from any public surface.

export const prerender = false;

import FieldGuideLayout from '@/components/layout/FieldGuideLayout.astro';
import { getDb } from '@/lib/db';

const adminPassword = import.meta.env.ADMIN_PASSWORD;
const sessionCookie = Astro.cookies.get('fg_admin')?.value;

// Compute expected session token
const encoder = new TextEncoder();
const keyBuf = await crypto.subtle.digest('SHA-256', encoder.encode(adminPassword ?? 'unset'));
const expectedToken = Array.from(new Uint8Array(keyBuf))
  .map(b => b.toString(16).padStart(2, '0'))
  .join('');

const isAuth = sessionCookie === expectedToken;
const loginError = Astro.url.searchParams.get('error') === '1';

interface QueryRow {
  query_text: string;
  frequency: number;
  unique_ips: number;
  with_email: number;
  first_seen: string;
  last_seen: string;
  top_source: string | null;
}

let rows: QueryRow[] = [];
let dbError: string | null = null;
let noDb = false;

if (isAuth) {
  const sql = getDb();
  if (!sql) {
    noDb = true;
  } else {
    try {
      const result = await sql`
        SELECT
          query_text,
          COUNT(*)::int                                        AS frequency,
          COUNT(DISTINCT ip_hash)::int                         AS unique_ips,
          COUNT(email)::int                                    AS with_email,
          MIN(created_at)::text                                AS first_seen,
          MAX(created_at)::text                                AS last_seen,
          MODE() WITHIN GROUP (ORDER BY utm_source)            AS top_source
        FROM field_guide_queries
        GROUP BY query_text
        ORDER BY frequency DESC
        LIMIT 100
      `;
      rows = result as QueryRow[];
    } catch (err) {
      dbError = err instanceof Error ? err.message : String(err);
    }
  }
}

function shortDate(iso: string) {
  return iso?.slice(0, 10) ?? '—';
}
---
<FieldGuideLayout
  title="Field Guide Admin"
  description="Field Guide query analytics — internal tool."
>
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <div style="padding: 80px 24px 120px; max-width: 1100px; margin: 0 auto;">

    {!isAuth ? (
      <div style="max-width: 360px; margin: 0 auto; padding-top: 60px;">
        <p
          style="font-family:var(--font-family-display);font-size:10px;font-weight:700;
                 text-transform:uppercase;letter-spacing:0.15em;
                 color:var(--color-guide-accent);margin-bottom:20px;"
        >
          BayShine · Field Guide Admin
        </p>

        <form method="POST" action="/api/field-guide/admin-auth" style="display:flex;flex-direction:column;gap:12px;">
          <label
            for="pw"
            style="font-family:var(--font-family-ui);font-size:12px;
                   color:var(--color-guide-text-muted);display:block;margin-bottom:4px;"
          >
            Password
          </label>
          <input
            id="pw"
            type="password"
            name="password"
            required
            autocomplete="current-password"
            style="background:var(--color-guide-surface);border:1px solid var(--color-guide-border);
                   color:var(--color-guide-heading);padding:10px 12px;font-size:14px;
                   font-family:var(--font-family-sans);outline:none;caret-color:var(--color-guide-accent);"
          />
          <button
            type="submit"
            style="background:var(--color-guide-accent);color:#1a1410;border:none;
                   padding:10px 18px;font-family:var(--font-family-display);
                   font-weight:700;font-size:13px;cursor:pointer;align-self:flex-start;"
          >
            Enter
          </button>
        </form>
        {loginError && (
          <p style="color:#ef5350;font-size:12px;margin-top:10px;">Incorrect password.</p>
        )}
      </div>
    ) : noDb ? (
      <div style="padding-top:40px;">
        <p style="color:var(--color-guide-text-muted);font-size:14px;">
          No database configured. Set DATABASE_URL to enable analytics.
        </p>
      </div>
    ) : dbError ? (
      <div style="padding-top:40px;">
        <p style="color:#e57373;font-size:14px;">DB error: {dbError}</p>
      </div>
    ) : (
      <div>
        <p
          style="font-family:var(--font-family-display);font-size:10px;font-weight:700;
                 text-transform:uppercase;letter-spacing:0.15em;
                 color:var(--color-guide-accent);margin-bottom:6px;"
        >
          BayShine · Field Guide Admin
        </p>
        <h1
          style="font-family:var(--font-family-display);font-size:24px;font-weight:700;
                 color:var(--color-guide-heading);margin:0 0 6px;"
        >
          Query Analytics
        </h1>
        <p style="font-size:13px;color:var(--color-guide-text-muted);margin:0 0 32px;">
          Top {rows.length} queries, sorted by frequency.
        </p>

        {rows.length === 0 ? (
          <p style="font-size:14px;color:var(--color-guide-text-muted);">
            No queries captured yet.
          </p>
        ) : (
          <div style="overflow-x:auto;">
            <table
              style="width:100%;border-collapse:collapse;font-size:13px;
                     font-family:var(--font-family-sans);"
            >
              <thead>
                <tr style="border-bottom:1px solid var(--color-guide-border);">
                  {['Query', 'Count', 'Unique IPs', 'w/ Email', 'First Seen', 'Top Source'].map(col => (
                    <th
                      style="text-align:left;padding:8px 12px;font-family:var(--font-family-display);
                             font-size:10px;font-weight:700;text-transform:uppercase;
                             letter-spacing:0.1em;color:var(--color-guide-text-muted);"
                    >
                      {col}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {rows.map((row, i) => (
                  <tr
                    style={`border-bottom:1px solid var(--color-guide-border);
                            background:${i % 2 === 0 ? 'transparent' : 'var(--color-guide-surface)'};`}
                  >
                    <td style="padding:10px 12px;color:var(--color-guide-heading);max-width:340px;">
                      {row.query_text}
                    </td>
                    <td style="padding:10px 12px;font-family:var(--font-family-mono);
                               color:var(--color-guide-accent);font-size:12px;">
                      {row.frequency}
                    </td>
                    <td style="padding:10px 12px;font-family:var(--font-family-mono);
                               color:var(--color-guide-text-muted);font-size:12px;">
                      {row.unique_ips}
                    </td>
                    <td style="padding:10px 12px;font-family:var(--font-family-mono);
                               color:var(--color-guide-text-muted);font-size:12px;">
                      {row.with_email}
                    </td>
                    <td style="padding:10px 12px;font-family:var(--font-family-mono);
                               color:var(--color-guide-text-muted);font-size:11px;">
                      {shortDate(row.first_seen)}
                    </td>
                    <td style="padding:10px 12px;color:var(--color-guide-text-muted);font-size:12px;">
                      {row.top_source ?? '—'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    )}

  </div>
</FieldGuideLayout>
