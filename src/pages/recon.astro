---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Divider from '@/components/ui/Divider.astro';
import RelatedBlogBox from '@/components/sections/RelatedBlogBox.astro';
---
<BaseLayout
  title="Heavy Recon: Deep Detail for Neglected Vehicles"
  description="Heavy-condition vehicle reconditioning in Pasco County and North Hillsborough. Trade-ins, long-term neglect, severe staining. Restored to a sellable standard."
>
  <section class="noise-overlay bg-bay-navy py-24 px-4 section-bevel">
    <div class="container mx-auto max-w-3xl">
      <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">Heavy Condition</p>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-bay-white mb-6 leading-tight">
        Heavy Recon.
      </h1>
      <p class="text-bay-slate text-lg leading-relaxed mb-4 max-w-xl">
        For vehicles that have been neglected, heavily soiled, or come in as trade-ins.
        Odor treatment, deep extraction, paint decontamination, and full restoration to
        a sellable or livable standard.
      </p>
      <p class="text-bay-slate text-sm leading-relaxed mb-10 max-w-xl">
        Recon is not a longer version of a standard detail. The chemistry is more aggressive,
        the process is multi-stage, and time investment is higher. This service exists for
        vehicles where a standard detail would not be sufficient.
      </p>
      <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
        Book Heavy Recon
      </Button>
    </div>
  </section>

  <Divider />

  <section class="py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal mb-10">
        <h2 class="font-display font-bold text-2xl text-bay-white mb-4">What heavy recon covers</h2>
        <p class="text-bay-slate leading-relaxed max-w-2xl">
          Recon is not a longer version of a standard detail. The chemistry is different,
          the process is more aggressive, and the time investment is higher. This service
          exists for vehicles where a standard detail would not be sufficient.
        </p>
      </div>

      <div class="reveal grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          'Heavy interior extraction: upholstery, carpet, floor mats',
          'Enzymatic odor treatment: smoke, pet, mildew',
          'Ozone treatment where applicable',
          'Steam cleaning: seats, door panels, headliner',
          'Full paint decontamination',
          'Iron contamination removal',
          'Tar, overspray, and adhesive removal',
          'Hard-water spot correction where feasible',
          'Scrub and extract: center console, crevices, vents',
          'Polymer sealant applied post-correction',
        ].map(item => (
          <div class="flex gap-3 text-bay-slate text-sm">
            <span class="text-bay-gold flex-shrink-0" aria-hidden="true">·</span>
            <span>{item}</span>
          </div>
        ))}
      </div>

      <div class="reveal mt-10 border-l-2 border-bay-gold pl-6">
        <p class="text-bay-bone text-sm font-semibold mb-2">Pricing note</p>
        <p class="text-bay-slate text-sm leading-relaxed">
          Recon is quoted individually after inspection. Vehicle condition, odor type,
          and contamination level determine time required. Use the quote estimator for
          a range, then book a walkthrough for the confirmed number.
        </p>
        <p class="text-bay-slate text-sm leading-relaxed mt-3">
          Vehicles completing heavy recon are often good candidates for <a href="/ceramic-coating" class="text-bay-gold hover:text-[#d9bc79] underline underline-offset-2 transition-colors">ceramic coating</a> afterward. Paint correction is already part of the recon process; coating goes on a properly prepared surface.
        </p>
      </div>
    </div>
  </section>

  <Divider />

  <RelatedBlogBox topic="recon" />

  <section class="py-16 px-4">
    <div class="container mx-auto max-w-xl text-center">
      <Button href="/quote" variant="secondary" class="text-base px-8 py-3.5">Get a Range Estimate</Button>
      <p class="text-bay-slate text-sm mt-4">Walkthrough required before scheduling recon.</p>
    </div>
  </section>
</BaseLayout>
