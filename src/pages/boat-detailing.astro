---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Divider from '@/components/ui/Divider.astro';
import PhotoPlaceholder from '@/components/ui/PhotoPlaceholder.astro';
---
<BaseLayout
  title="Boat Detailing — Marine Gelcoat & Hull Cleaning"
  description="Mobile marine detailing in Pasco County and North Hillsborough. Gelcoat cleaning, oxidation removal, hull restoration. Ready for water."
>
  <section class="noise-overlay bg-bay-navy py-24 px-4">
    <div class="container mx-auto max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">Marine</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-bay-white mb-5 leading-tight">
          Boat Detailing.
        </h1>
        <p class="text-bay-slate text-lg leading-relaxed mb-8">
          Gelcoat cleaned, oxidation cut, hull restored. Marine surfaces require different
          chemistry than automotive paint. The process accounts for that. Done at your
          location — no haul or trailer required.
        </p>
        <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
          Book Marine Detail
        </Button>
      </div>
      <div class="reveal">
        <PhotoPlaceholder
          description="Boat detail — hull oxidation removal, gelcoat restored, water reflection visible"
          aspectRatio="4/3"
          class="rounded-sm"
        />
      </div>
    </div>
  </section>

  <Divider />

  <section class="py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="font-display font-bold text-2xl text-bay-white mb-6">Services</h2>
          <ul class="space-y-3 text-bay-slate text-sm">
            {[
              'Gelcoat cleaning and polishing',
              'Oxidation removal — mild to heavy',
              'Hull wash and teak cleaning',
              'Vinyl and upholstery treatment',
              'Stainless hardware polishing',
              'Cockpit deep clean',
              'Protective wax or gelcoat sealant application',
            ].map(item => (
              <li class="flex gap-3">
                <span class="text-bay-gold mt-0.5 flex-shrink-0" aria-hidden="true">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="font-display font-bold text-2xl text-bay-white mb-6">What to know</h2>
          <ul class="space-y-3 text-bay-slate text-sm">
            {[
              'Service requires boat to be on trailer or on-site lift — not in water',
              'Oxidation severity is assessed at walkthrough and affects pricing',
              'Fiberglass and gelcoat require different compounds than automotive paint',
              'Heavy oxidation: multiple passes required',
              'Salt residue and water stain treatment included',
            ].map(item => (
              <li class="flex gap-3">
                <span class="text-bay-gold mt-0.5 flex-shrink-0" aria-hidden="true">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Divider />

  <section class="py-16 px-4">
    <div class="container mx-auto max-w-xl text-center">
      <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">Book Marine Detail</Button>
      <p class="text-bay-slate text-sm mt-4">Pricing based on condition and boat size. Quoted at walkthrough.</p>
    </div>
  </section>
</BaseLayout>
