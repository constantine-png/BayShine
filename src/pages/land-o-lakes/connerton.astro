---
// Neighborhood landing page for Connerton, Land O' Lakes.
// Targets well water mineral deposits, long-term vehicle care, and community service model.
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Divider from '@/components/ui/Divider.astro';
import Pause from '@/components/ui/Pause.astro';
import RelatedBlogBox from '@/components/sections/RelatedBlogBox.astro';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['LocalBusiness', 'AutoWash', 'ProfessionalService'],
      '@id': 'https://bayshine.net/#business',
      name: 'BayShine Detailing',
      telephone: '+18133245522',
      url: 'https://bayshine.net',
      address: {
        '@type': 'PostalAddress',
        addressLocality: "Land O' Lakes",
        addressRegion: 'FL',
        postalCode: '34638',
        addressCountry: 'US',
      },
      areaServed: {
        '@type': 'City',
        name: "Land O' Lakes",
        containsPlace: { '@type': 'Neighborhood', name: 'Connerton' },
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bayshine.net' },
        { '@type': 'ListItem', position: 2, name: "Land O' Lakes", item: 'https://bayshine.net/land-o-lakes' },
        { '@type': 'ListItem', position: 3, name: 'Connerton', item: 'https://bayshine.net/land-o-lakes/connerton' },
      ],
    },
  ],
};
---
<BaseLayout
  title="Auto Detailing in Connerton, Land O' Lakes | BayShine"
  description="Mobile auto detailing in Connerton, Land O' Lakes. BayShine serves Connerton residents with exterior detail, full detail, ceramic coating, and the Standing Detail program. We come to you."
  canonical="https://bayshine.net/land-o-lakes/connerton"
  schema={schema}
  keywords="auto detailing Connerton Land O Lakes, mobile detailing Connerton FL, car detailing 34637"
>

  <!-- HERO -->
  <section class="noise-overlay py-24 px-4 min-h-[60vh] flex flex-col justify-center">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal">
        <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">CONNERTON, LAND O' LAKES, FL</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-bay-white leading-[1.08] mb-6 tracking-tight" style="text-shadow: 0 2px 24px rgba(15,27,45,0.7);">
          Mobile auto detailing.<br />Connerton, Land O' Lakes.
        </h1>
        <p class="text-bay-slate text-lg leading-relaxed mb-10 max-w-2xl">
          Connerton is an established, master-planned community with larger lots and more mature landscaping than most of Pasco County. Vehicles here deal with organic debris from established tree coverage, Pasco County well water mineral deposits on paint and glass, and the straightforward reality that HOA-maintained neighborhoods expect services to come to you. We do.
        </p>
        <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
          Schedule a Service in Connerton
        </Button>
      </div>
    </div>
  </section>

  <Divider />

  <!-- WHY IT MATTERS -->
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal mb-12">
        <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">WHAT'S HAPPENING TO YOUR PAINT</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white leading-tight">
          Three conditions every Connerton vehicle faces.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
        <div class="border-l-2 border-bay-gold pl-5">
          <p class="font-semibold text-bay-white text-sm mb-2">Well water mineral etching</p>
          <p class="text-bay-slate text-sm leading-relaxed">
            Pasco County's aquifer is high in calcium and magnesium. When well water dries on paint, it leaves calcium deposits that bond to clear coat. Over time they etch the surface beneath them. A standard wash moves them; it doesn't remove them. Decontamination chemistry does.
          </p>
        </div>
        <div class="border-l-2 border-bay-gold pl-5">
          <p class="font-semibold text-bay-white text-sm mb-2">Protection for vehicles kept long-term</p>
          <p class="text-bay-slate text-sm leading-relaxed">
            Connerton residents tend to keep vehicles longer than average. That makes protection economics work differently: a ceramic coating applied at 30,000 miles pays back over 80,000 more. Regular decontamination prevents the surface degradation that makes paint correction necessary.
          </p>
        </div>
        <div class="border-l-2 border-bay-gold pl-5">
          <p class="font-semibold text-bay-white text-sm mb-2">On-site service that fits the community</p>
          <p class="text-bay-slate text-sm leading-relaxed">
            Connerton residents use home services: lawn, pest, HVAC. Detailing works the same way. We arrive, work at your driveway, and leave. No drop-off, no coordination outside your property, no shop waiting room. The service fits how the community already operates.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Divider />

  <!-- STANDING DETAIL -->
  <section class="noise-overlay section-bevel bg-bay-deep py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal">
        <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">RECURRING PROTECTION</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white mb-6 leading-tight">
          The Standing Detail program.
        </h2>
        <p class="text-bay-slate text-lg leading-relaxed mb-8 max-w-2xl">
          The six-week cycle does not ask you to remember when your vehicle was last cleaned. We hold the slot. Every six weeks, we run a maintenance detail that covers what accumulates between visits: mineral deposits from the next rain cycle, pollen from the spring season, UV degradation on horizontal panels. The baseline is set once. After that, the vehicle stays there.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
          {[
            { label: 'Priority Slot', desc: 'Your recurring time is held. No competing for availability.' },
            { label: 'Locked Rate', desc: 'The price you start at is the price you keep.' },
            { label: 'Cancel Anytime', desc: 'No contracts. No cancellation fee. No pressure.' },
          ].map(item => (
            <div class="border-l-2 border-bay-gold pl-5">
              <p class="font-semibold text-bay-white text-sm mb-1">{item.label}</p>
              <p class="text-bay-slate text-sm">{item.desc}</p>
            </div>
          ))}
        </div>
        <Button href="/standing-detail" variant="primary" class="text-base px-8 py-3.5">
          How the Program Works
        </Button>
      </div>
    </div>
  </section>

  <Pause />

  <Divider />

  <!-- SERVICES -->
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal mb-12">
        <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">SERVICES</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white leading-tight">
          What we offer in Connerton.
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 reveal">
        {[
          {
            name: 'Exterior Detail',
            desc: 'Iron decontamination, synthetic clay bar, two-stage wash, polymer sealant. The baseline protection service.',
            href: '/exterior-detail',
          },
          {
            name: 'Full Detail',
            desc: 'Complete interior and exterior. Decontamination, clay, sealant, and a thorough interior clean in a single visit.',
            href: '/full-detail',
          },
          {
            name: 'Ceramic Coating',
            desc: 'Nano-silica coating bonded to clear coat. Years of hydrophobic protection against UV, mineral deposits, and chemical contamination.',
            href: '/ceramic-coating',
          },
          {
            name: 'Heavy Reconditioning',
            desc: 'For vehicles in rough condition. Paint correction, deep interior extraction, odor treatment, and full decontamination.',
            href: '/recon',
          },
        ].map(service => (
          <a
            href={service.href}
            class="group block border border-bay-slate/20 hover:border-bay-gold/50 bg-bay-deep/40 hover:bg-bay-deep/60 rounded-sm p-6 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold"
          >
            <h3 class="font-display font-semibold text-bay-white text-lg mb-2">{service.name}</h3>
            <p class="text-bay-slate text-sm leading-relaxed mb-4">{service.desc}</p>
            <span class="text-bay-gold text-sm font-medium group-hover:underline underline-offset-4">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Divider />

  <RelatedBlogBox topic="general" />

  <!-- FINAL CTA -->
  <section class="noise-overlay bg-bay-deep py-20 px-4">
    <div class="container mx-auto max-w-2xl text-center">
      <div class="reveal">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bay-white mb-4">
          Schedule a service in Connerton.
        </h2>
        <p class="text-bay-slate mb-8">
          Call or text (813) 324-5522, or book online. We respond within 2 hours.
        </p>
        <Button href="/contact" variant="primary" class="text-base px-8 py-3.5">
          Book Now
        </Button>
      </div>
    </div>
  </section>

</BaseLayout>
