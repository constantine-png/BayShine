---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Divider from '@/components/ui/Divider.astro';
import EmailCapture from '@/components/ui/EmailCapture.astro';
---
<BaseLayout
  title="Bay Shine Tools — Brushes & Applicators"
  description="A line of detailing brushes and sponge applicators in development. Sign up to get early access."
>
  <section class="noise-overlay min-h-screen flex items-center bg-bay-navy py-24 px-4">
    <div class="container mx-auto max-w-2xl">
      <p class="text-bay-gold text-xs font-semibold uppercase tracking-widest mb-4">Coming Soon</p>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-bay-white mb-6 leading-tight">
        Bay Shine Tools.
      </h1>
      <p class="text-bay-bone text-lg leading-relaxed mb-6">
        A line of detailing brushes and sponge applicators built to the standard the
        work requires. Not rebranded imports — designed for the sequences and surfaces
        professionals actually work with.
      </p>
      <p class="text-bay-slate leading-relaxed mb-10">
        In development. Subscribers will have early access before the general release.
      </p>

      <Divider class="mb-10" />

      <div>
        <EmailCapture
          label="Get early access."
          source="tools"
        />
        <p class="text-bay-slate text-xs mt-4">Early access only. No sales emails until the line is available.</p>
      </div>
    </div>
  </section>
</BaseLayout>
