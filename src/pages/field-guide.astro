---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import FieldGuideBook from '@/components/islands/FieldGuideBook';
import Divider from '@/components/ui/Divider.astro';
---
<BaseLayout
  title="The Detailer's Field Guide"
  description="Eight chapters on paint chemistry, correction, protection, and the professional mindset. Written from production experience by Bay Shine Detailing."
>
  <!-- Header -->
  <section class="noise-overlay py-20 px-4 bg-bay-navy">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal">
        <p class="font-display text-[10px] font-bold uppercase tracking-[0.2em] text-bay-gold mb-5">Bay Shine · Reference Material</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-bay-white mb-5 leading-[1.06] tracking-tight">
          The Detailer's<br />Field Guide.
        </h1>
        <p class="text-bay-bone text-lg leading-relaxed max-w-lg mb-4">
          Eight chapters on paint chemistry, surface correction, protection systems, and
          the professional mindset. Written from production experience.
        </p>
        <p class="text-bay-slate text-sm">
          Not forum aggregation. Not product marketing. Field-tested technique.
        </p>
      </div>
    </div>
  </section>

  <Divider />

  <!-- Book island -->
  <section class="py-16 px-4 bg-bay-navy">
    <div class="container mx-auto max-w-3xl">
      <div class="reveal mb-8">
        <p class="font-display text-xs font-semibold uppercase tracking-widest text-bay-slate mb-2">Preview</p>
        <h2 class="font-display font-bold text-2xl text-bay-white">Eight chapters. Open the book.</h2>
      </div>
      <FieldGuideBook captureSource="field-guide-book" client:visible />
    </div>
  </section>

  <Divider />

  <!-- What's inside -->
  <section class="py-16 px-4 section-bevel bg-bay-deep">
    <div class="container mx-auto max-w-4xl">
      <div class="reveal mb-10">
        <h2 class="font-display font-bold text-2xl text-bay-white mb-2">What's inside</h2>
        <p class="text-bay-slate text-sm">Topics covered across the eight chapters.</p>
      </div>
      <div class="reveal grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-3">
        {[
          'Paint layer system and depth measurement',
          'Wash chemistry and contact scratch prevention',
          'Iron fallout, clay, and full decontamination',
          'Compound → polish → finish correction sequence',
          'Wax, sealant, and ceramic coating differences',
          'Interior deep clean — steam, extraction, sequence',
          'Marine gel coat and salt contamination protocol',
          'Fleet throughput and lot logistics',
        ].map(item => (
          <div class="flex items-start gap-3 py-2 border-t border-bay-slate/10">
            <span class="text-bay-gold font-bold text-xs mt-0.5 shrink-0">—</span>
            <span class="text-bay-bone text-sm leading-snug">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
