---
// Field Guide front door — search-first, taxonomy tiles, recent articles, editorial signal.
// Uses FieldGuideLayout (not BaseLayout) for the [data-guide-scope] CSS split.

import FieldGuideLayout from '@/components/layout/FieldGuideLayout.astro';
import FieldGuideSearch from '@/components/field-guide/FieldGuideSearch';
import CategoryTiles from '@/components/field-guide/CategoryTiles.astro';
import Divider from '@/components/ui/Divider.astro';
import { getCollection } from 'astro:content';

// Fetch published field guide articles, newest first, show 6
const allArticles = await getCollection('fieldGuideScenarios');
const articles = allArticles
  .filter(a => !a.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categoryLabel: Record<string, string> = {
  paint: 'Paint', interior: 'Interior', glass: 'Glass', wheels: 'Wheels',
  trim: 'Trim', coating: 'Coating', contamination: 'Contamination',
  correction: 'Correction', tools: 'Tools', general: 'General',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'BayShine Field Guide',
  description:
    'An index of detailing scenarios covering paint, interior, glass, wheels, trim, coating, contamination, and correction. Each entry covers one problem: cause, chemistry, and solution sequence.',
  url: 'https://bayshine.net/field-guide',
  isPartOf: {
    '@type': 'WebSite',
    name: 'BayShine Detailing',
    url: 'https://bayshine.net',
  },
};
---
<FieldGuideLayout
  title="Field Guide – BayShine Detailing"
  description="An index of detailing scenarios. Every entry covers one problem: cause, chemistry, and solution sequence. Paint, interior, glass, wheels, trim, coating, contamination, correction."
  schema={schema}
  bodyClass="page-field-guide"
>

  <!-- ── Hero / Search front door ──────────────────────────────── -->
  <section
    class="guide-section noise-overlay"
    style="padding: 96px 24px 72px; background-color: var(--color-guide-bg);"
  >
    <div style="max-width: 720px; margin: 0 auto;">

      <p
        class="font-display font-bold uppercase"
        style="font-size:10px;letter-spacing:0.2em;color:var(--color-guide-accent);margin-bottom:20px;"
      >
        BayShine · Field Guide
      </p>

      <h1
        class="font-display font-bold"
        style="font-size:clamp(36px,6vw,56px);line-height:1.06;letter-spacing:0.03em;
               color:var(--color-guide-heading);margin:0 0 20px;"
      >
        Describe the problem.
      </h1>

      <p style="font-size:16px;color:var(--color-guide-text-muted);max-width:520px;line-height:1.65;margin:0 0 40px;">
        The Field Guide is an index of detailing scenarios. Every entry covers one
        problem: cause, chemistry, and solution sequence.
      </p>

      <FieldGuideSearch captureSource="field-guide-hero" client:load />

      <p style="margin-top:20px;font-size:12px;color:var(--color-guide-text-muted);font-family:var(--font-family-mono);">
        No results yet – tell us what you're looking for. We build the most-requested scenarios first.
      </p>

    </div>
  </section>

  <Divider />

  <!-- ── Category tiles ─────────────────────────────────────────── -->
  <section
    class="guide-section"
    style="padding: 64px 24px 80px; background-color: var(--color-guide-bg);"
    aria-labelledby="categories-heading"
  >
    <div style="max-width: 1080px; margin: 0 auto;">

      <p
        class="font-display font-bold uppercase"
        style="font-size:10px;letter-spacing:0.2em;color:var(--color-guide-accent);margin-bottom:10px;"
      >
        Browse by category
      </p>

      <h2
        id="categories-heading"
        class="font-display font-bold"
        style="font-size:28px;color:var(--color-guide-heading);margin:0 0 10px;"
      >
        What's in the guide.
      </h2>

      <p style="font-size:14px;color:var(--color-guide-text-muted);margin:0 0 32px;max-width:520px;line-height:1.6;">
        Every scenario falls into one of these categories. The counts reflect what's
        published today.
      </p>

      <CategoryTiles />

    </div>
  </section>

  <Divider />

  <!-- ── From the Field Guide — content collection articles ────── -->
  {articles.length > 0 && (
    <section
      class="guide-section"
      style="padding: 64px 24px 80px; background-color: var(--color-guide-bg);"
      aria-labelledby="articles-heading"
    >
      <div style="max-width: 1080px; margin: 0 auto;">

        <p
          class="font-display font-bold uppercase"
          style="font-size:10px;letter-spacing:0.2em;color:var(--color-guide-accent);margin-bottom:10px;"
        >
          From the Field Guide
        </p>

        <h2
          id="articles-heading"
          class="font-display font-bold"
          style="font-size:28px;color:var(--color-guide-heading);margin:0 0 32px;"
        >
          Field Guide Articles
        </h2>

        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:var(--color-guide-border,rgba(255,255,255,0.08));">
          {articles.map(article => (
            <a
              href={`/field-guide/articles/${article.slug}`}
              class="guide-article-card"
              style="display:block;background:var(--color-guide-surface,rgba(255,255,255,0.03));padding:28px 24px;text-decoration:none;transition:background 200ms;"
            >
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                <span
                  class="font-display font-bold uppercase"
                  style="font-size:9px;letter-spacing:0.18em;color:var(--color-guide-accent);"
                >
                  {categoryLabel[article.data.category] ?? article.data.category}
                </span>
                {article.data.severity && (
                  <span
                    class="font-display font-bold uppercase"
                    style={`font-size:9px;letter-spacing:0.14em;padding:2px 6px;border-radius:2px;${
                      article.data.severity === 'quick-fix'
                        ? 'color:#C9A961;background:rgba(201,169,97,0.12);'
                        : article.data.severity === 'advanced'
                        ? 'color:#f87171;background:rgba(248,113,113,0.12);'
                        : 'color:#fb923c;background:rgba(251,146,60,0.12);'
                    }`}
                  >
                    {article.data.severity === 'quick-fix' ? 'Quick Fix' : article.data.severity === 'advanced' ? 'Advanced' : 'Moderate'}
                  </span>
                )}
              </div>

              <h3
                class="font-display font-bold"
                style="font-size:15px;color:var(--color-guide-heading);margin:0 0 8px;line-height:1.35;letter-spacing:-0.01em;"
              >
                {article.data.title}
              </h3>

              <p
                style="font-size:13px;color:var(--color-guide-text-muted);line-height:1.6;margin:0 0 14px;"
              >
                {article.data.description}
              </p>

              <span
                class="font-display font-bold uppercase"
                style="font-size:9px;letter-spacing:0.16em;color:var(--color-guide-accent);opacity:0.7;"
              >
                {article.data.readTime} min read &rarr;
              </span>
            </a>
          ))}
        </div>

      </div>
    </section>

    <Divider />
  )}

  <!-- ── Editorial signal ───────────────────────────────────────── -->
  <section
    style="padding: 64px 24px 96px; background-color: var(--color-guide-bg);"
  >
    <div style="max-width: 560px; margin: 0 auto; text-align: center;">

      <h3
        class="font-display font-bold"
        style="font-size:18px;color:var(--color-guide-heading);margin:0 0 14px;line-height:1.3;"
      >
        Written from production, not forums.
      </h3>

      <p style="font-size:15px;color:var(--color-guide-text-muted);line-height:1.7;margin:0 0 20px;">
        The Field Guide covers scenarios we've actually encountered on jobs in Pasco County.
        No aggregated forum advice, no product marketing. Every entry is field-tested.
      </p>

      <p style="font-size:12px;color:var(--color-guide-text-muted);line-height:1.6;opacity:0.7;">
        Affiliate products listed in each scenario are tools we use or have evaluated.
        Commission disclosures are inline.
      </p>

    </div>
  </section>

</FieldGuideLayout>

<style is:global>
  /* Phone number in header: white on guide page — gold reads poorly against the deep background */
  .page-field-guide #site-header a[href="tel:+18133245522"] {
    color: var(--color-bay-white);
  }
  .page-field-guide #site-header a[href="tel:+18133245522"]:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  /* Article card hover — subtle surface lift, no bounce */
  .guide-article-card:hover {
    background: rgba(255, 255, 255, 0.06) !important;
  }
  .guide-article-card:focus-visible {
    outline: 2px solid var(--color-bay-gold, #C9A961);
    outline-offset: -2px;
  }
</style>
