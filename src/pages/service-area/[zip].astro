---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Divider from '@/components/ui/Divider.astro';
import ServiceCard from '@/components/ui/ServiceCard.astro';
import FAQAccordion from '@/components/islands/FAQAccordion';
import { SERVICE_AREA, type ZipEntry } from '@/data/serviceArea';
import type { Service } from '@/data/services';
import type { FAQ } from '@/data/faq';

export function getStaticPaths() {
  return SERVICE_AREA
    .filter(z => z.priority === 'high')
    .map(z => ({ params: { zip: z.code }, props: { entry: z } }));
}

interface Props {
  entry: ZipEntry;
}

const { entry } = Astro.props;
const { code, city, neighborhoods } = entry;

function joinNeighborhoods(ns: string[]): string {
  if (ns.length === 0) return '';
  if (ns.length === 1) return ns[0];
  if (ns.length === 2) return `${ns[0]} and ${ns[1]}`;
  return ns.slice(0, -1).join(', ') + ', and ' + ns[ns.length - 1];
}

const neighborhoodLabel = joinNeighborhoods(neighborhoods);

// Per-zip content — unique copy, not templated prose
type ZipContent = {
  metaDescription: string;
  standingDetailHeadline: string;
  standingDetailCopy: string;
  localContextParagraph: string;
  faqs: FAQ[];
};

const ZIP_CONTENT: Record<string, ZipContent> = {
  '33556': {
    metaDescription:
      'Mobile auto detailing in Odessa, FL (33556). Full detail, ceramic coating, and the Standing Detail recurring program for Keystone, Eagles, and Starkey Ranch.',
    standingDetailHeadline: 'The recurring detail program for Odessa, Keystone, and the Eagles.',
    standingDetailCopy:
      'Six-week rhythm, locked rate, priority slot. Keystone and the Eagles are multi-vehicle households by design: three-car garages are standard. The program front-loads the investment with a baseline visit that resets the paint to a proper standard, then holds it through maintenance visits every six weeks. Salt-air humidity from Old Tampa Bay accelerates oxidation; the cadence interrupts that cycle before it requires cutting.',
    localContextParagraph:
      'Odessa sits close enough to Old Tampa Bay that salt-air humidity is a year-round factor on paint. It settles on clear coat and works on it incrementally; you don\'t see the damage until you\'re under a light at the right angle. UV exposure on Keystone\'s open lakefront lots is among the highest in the service area; west-facing driveways bake through the afternoon. The airborne particulate here is primarily organic: live oak pollen in late spring, pine sap during growth cycles, and the persistent damp that keeps algae growing in driveway cracks. Starkey Ranch residents near the trail system pick up road spray from unpaved surfaces during dry-to-wet transitions. Eagles community vehicles tend toward full-size SUVs and trucks, which accumulate iron fallout on horizontal panels (roof, hood, trunk deck) faster than smaller vehicles because the surface area is larger and sits more directly in the fallout path. A six-week service interval handles all of it before anything has time to etch into the clear coat. One-time exterior details, full details, and ceramic coating are all available for vehicles outside the recurring program.',
    faqs: [
      {
        question: 'Do you serve Keystone and the Eagles in Odessa?',
        answer:
          'Yes. Both communities are in the 33556 service area and are priority coverage zones for the Standing Detail program. Service runs at your location: driveway or garage, your preference.',
      },
      {
        question: 'How long does a full detail take in Odessa?',
        answer:
          'A full detail on a standard sedan or mid-size SUV typically runs 4 to 6 hours. Larger vehicles (full-size trucks, three-row SUVs) take 5 to 7 hours depending on condition. Heavy recon work on neglected vehicles is assessed on-site before a time estimate is given.',
      },
      {
        question: 'Can I schedule a recurring 6-week detail in 33556?',
        answer:
          'Yes. The Standing Detail program is available throughout 33556. The first visit is a baseline full detail at the standard rate. Every visit after that is a maintenance detail at a locked rate with priority scheduling: same window, six-week cadence, cancel anytime.',
      },
    ],
  },
  '33548': {
    metaDescription:
      'Mobile auto detailing in Lutz, FL (33548). Full detail, ceramic coating, and the Standing Detail recurring program for Cheval and Lake Fern.',
    standingDetailHeadline: 'The recurring detail program for Cheval and Lake Fern.',
    standingDetailCopy:
      'Cheval runs on a schedule. Residents here maintain everything: the lawn, the pool, the property lines. The Standing Detail fits the same operational logic: six weeks, same slot, locked rate, cancel anytime. Vehicles in Cheval trend toward daily-driven luxury, which means deferred maintenance costs more to correct. The program front-loads that investment with a baseline detail, then holds the standard through maintenance visits. Fertilizer drift and heavy tree pollen are the primary contamination drivers in this zip; both are manageable on a consistent cadence.',
    localContextParagraph:
      'Cheval is a gated golf community in Hillsborough County, and the microclimates around golf courses create a specific detailing challenge. Fertilizer drift from irrigation and course maintenance lands on paint and becomes corrosive when it dries and sits through a heat cycle. Lake Fern\'s tree canopy means heavy pollen and sap loading from spring through summer: live oaks shed pollen in sheets from March into May, and vehicles parked outdoors more than a day will have a visible coating. Cheval\'s inward-facing street design reduces highway fallout but doesn\'t eliminate it; residents commuting to the I-275 corridor bring back brake dust and road tar on every round trip. The combination of organic fallout and chemical fertilizer residue makes this zip harder on paint than it looks from the outside. Ceramic coating holds well here when applied over a properly decontaminated surface; the protection layer intercepts the contamination cycle before it can etch. Left untreated, the etch cycle runs fast under Florida heat.',
    faqs: [
      {
        question: 'Do you serve Cheval and Lake Fern in Lutz?',
        answer:
          'Yes. Both communities are in the 33548 coverage area and are priority zones for the Standing Detail program. Service is fully mobile: your driveway, gated community or not. For gated access, provide the gate code when you book.',
      },
      {
        question: 'How long does a full detail take in Lutz 33548?',
        answer:
          'A standard full detail runs 4 to 6 hours on a sedan or mid-size SUV. Larger vehicles take longer. If the vehicle has been sitting for an extended period or has significant contamination, the baseline visit may run longer; that\'s typical for the first session before the maintenance cycle begins.',
      },
      {
        question: 'Can I schedule a recurring 6-week detail in 33548?',
        answer:
          'Yes. The Standing Detail program is active in 33548. First visit establishes the baseline at the standard full-detail rate, then maintenance visits run on a six-week cadence at a locked rate. Priority slot means the same window each cycle.',
      },
    ],
  },
  '33558': {
    metaDescription:
      'Mobile auto detailing in Lutz, FL (33558). Full detail, ceramic coating, and the Standing Detail program for Steinbrenner and Van Dyke Farms neighborhoods.',
    standingDetailHeadline: 'The recurring detail program for Steinbrenner and Van Dyke Farms.',
    standingDetailCopy:
      'Van Dyke Farms and the Steinbrenner corridor sit in active-development territory. New construction brings concrete dust, drywall overspray, and road base that finds its way onto paint in ways that aren\'t obvious until the light catches the surface. The Standing Detail program catches that contamination before it bonds into the clear coat. Six-week cadence, locked rate, priority scheduling, and a baseline first visit that removes what\'s already there before the maintenance rhythm starts.',
    localContextParagraph:
      'The 33558 zip sits in a transitional stretch: established subdivisions on one end, active build sites on the other on one end, active build sites on the other. Construction fallout is a real recurring problem: fine concrete particulate, drywall dust, and road-base overspray drift from active work sites on windy days and settle on paint in ways that don\'t wash off with a standard wash. Van Dyke Road carries heavy service vehicle traffic, and vehicles near the main corridors accumulate significant brake dust on wheels and lower rockers. The open terrain between subdivisions also means higher wind-driven pollen loading than the more canopied zips to the east. Sun exposure on west-facing driveways here is aggressive; UV degradation on unprotected clear coat is measurable year over year. Ceramic coating applied over a properly decontaminated and corrected surface performs significantly better in this zip than in shadier environments, because the protection layer intercepts what would otherwise be direct UV contact on a daily basis. One-time details are also available for any vehicle in the area.',
    faqs: [
      {
        question: 'Do you serve Steinbrenner and Van Dyke Farms in Lutz?',
        answer:
          'Yes. Both neighborhoods are in the 33558 service area and are covered under the Standing Detail program. Service runs at your location: contact or booking form to get on the schedule.',
      },
      {
        question: 'How long does a full detail take in Lutz 33558?',
        answer:
          'Standard sedan or mid-size SUV: 4 to 6 hours. Full-size trucks and three-row SUVs: 5 to 7 hours. Vehicles with construction dust contamination may require additional decontamination time on the first visit; this is typical for new-construction areas.',
      },
      {
        question: 'Can I schedule a recurring 6-week detail in 33558?',
        answer:
          'Yes. The Standing Detail program is available in 33558. The first visit is a full baseline detail at the standard rate. Subsequent visits run at a locked maintenance rate on a six-week cadence. Priority scheduling means the same window each cycle.',
