---
import { ASSET_REGISTRY } from '@/lib/assetRegistry';
import VideoLoop from '@/components/ui/VideoLoop.astro';

const PANELS = [
  {
    id: 'exterior',
    number: '01',
    title: 'Exterior Detail',
    tagline: 'Paint and glass, correct sequence.',
    body: 'Two-bucket wash, clay decontamination, iron fallout removal, and a finishing spray sealant. Every panel inspected under lighting. Not a rinse; a full exterior service.',
    stat: null,
    statLabel: null,
    videoKey: 'showcaseExterior' as const,
    videoFile: 'showcase-exterior.mp4',
  },
  {
    id: 'full',
    number: '02',
    title: 'Full Detail',
    tagline: 'Interior and exterior in one visit.',
    body: 'Complete interior extraction, steam cleaning of contact surfaces, odor elimination, and the full exterior protocol. Single-visit baseline for the Standing Detail program.',
    stat: null,
    statLabel: null,
    videoKey: 'showcaseInterior' as const,
    videoFile: 'showcase-interior.mp4',
  },
  {
    id: 'ceramic',
    number: '03',
    title: 'Ceramic Coating',
    tagline: 'Semi-permanent protection.',
    body: '9H-hardness SiO₂ coating applied after paint correction. Hydrophobic, scratch-resistant, and slick under UV. Requires proper prep; no shortcuts.',
    stat: '2 to 5 yr',
    statLabel: 'protection',
    videoKey: 'comparisonBayshine' as const,
    videoFile: 'comparison-bayshine-detail.mp4',
  },
  {
    id: 'fleet',
    number: '04',
    title: 'Fleet Programs',
    tagline: 'Throughput is the metric.',
    body: 'Standing schedule for 30 to 300+ vehicles. Walk the lot, set the cadence, receive a monthly invoice.',
    stat: null,
    statLabel: null,
    videoKey: 'ambientFleet' as const,
    videoFile: 'ambient-fleet.mp4',
  },
] as const;
---

<section class="py-20 px-4 overflow-hidden">
  <div class="container mx-auto max-w-5xl">
    <div class="reveal mb-10">
      <h2 class="font-display font-bold text-3xl text-bay-white mb-3">Services</h2>
      <p class="text-bay-slate text-sm">Every service is mobile. No drop-off, no waiting rooms.</p>
    </div>
  </div>

  <!-- Scroll container -->
  <div
    class="showcase-scroll relative"
    role="list"
    aria-label="Service panels"
  >
    <div
      id="showcase-track"
      class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 px-4
             md:px-[max(1rem,calc(50vw-40rem))]
             scrollbar-none
             [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {PANELS.map((panel, i) => (
        <article
          role="listitem"
          id={`panel-${panel.id}`}
          class="reveal snap-start shrink-0 w-[min(80vw,340px)] md:w-80
                 bg-bay-deep border border-bay-slate/10 rounded-sm
                 flex flex-col overflow-hidden section-bevel"
          style={`transition-delay: ${i * 60}ms`}
        >
          <!-- Video: show if asset registered, else no placeholder (Fix 6) -->
          {panel.videoKey && ASSET_REGISTRY[panel.videoKey] && (
            <div class="img-gloss aspect-video w-full overflow-hidden" aria-hidden="true">
              <VideoLoop src={`/assets/video/${panel.videoFile}`} ariaLabel={panel.title} class="w-full h-full object-cover" />
            </div>
          )}

          <div class="p-6 flex flex-col flex-1">
            <!-- Oversized outlined numeral — behind text, translucent gold -->
            <span class="block font-display text-[7em] leading-none font-bold text-transparent select-none pointer-events-none mb-2 -ml-2 overflow-hidden"
                  style="-webkit-text-stroke: 1px rgba(201,169,97,0.25);"
                  aria-hidden="true">
              {panel.number}
            </span>
            {panel.stat && (
              <div class="flex justify-end mb-3">
                <div class="text-right">
                  <div class="font-display font-bold text-bay-white text-sm">{panel.stat}</div>
                  {panel.statLabel && <div class="font-display text-[9px] text-bay-slate uppercase tracking-wider">{panel.statLabel}</div>}
                </div>
              </div>
            )}

            <h3 class="font-ui font-bold text-lg text-bay-white mb-1 leading-snug">
              {panel.title}
            </h3>
            <p class="font-display text-xs text-bay-gold mb-3 leading-snug">{panel.tagline}</p>
            <p class="text-bay-slate text-xs leading-relaxed flex-1">{panel.body}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Pagination dots -->
    <div
      id="showcase-dots"
      class="flex justify-center gap-2 mt-5"
      role="tablist"
      aria-label="Service panel navigation"
    >
      {PANELS.map((panel, i) => (
        <button
          role="tab"
          data-index={i}
          aria-label={panel.title}
          aria-selected={i === 0 ? 'true' : 'false'}
          class={`showcase-dot w-5 h-1 rounded-full transition-all duration-300
                  ${i === 0 ? 'bg-bay-gold' : 'bg-bay-slate/30'}`}
        />
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('showcase-track') as HTMLElement;
  const dots = document.querySelectorAll<HTMLButtonElement>('.showcase-dot');

  function getActiveIndex(): number {
    const panels = track.querySelectorAll<HTMLElement>('article');

    const trackRect = track.getBoundingClientRect();
    let closest = 0;
    let minDist = Infinity;
    panels.forEach((panel, i) => {
      const rect = panel.getBoundingClientRect();
      const dist = Math.abs(rect.left - trackRect.left);
      if (dist < minDist) { minDist = dist; closest = i; }
    });
    return closest;
  }

  function updateDots(active: number) {
    dots.forEach((dot, i) => {
      const isActive = i === active;
      dot.setAttribute('aria-selected', String(isActive));
      dot.className = dot.className
        .replace(/bg-bay-gold|bg-bay-slate\/30/g, '')
        .trim() + ` ${isActive ? 'bg-bay-gold' : 'bg-bay-slate/30'}`;
    });
  }

  track?.addEventListener('scroll', () => {
    updateDots(getActiveIndex());
  }, { passive: true });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      const panels = track.querySelectorAll<HTMLElement>('article');
      panels[i]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    });
  });
</script>
