---
// Static gold-line divider with centered droplet. No scroll animation.
---

<div class="shoreline-divider" aria-hidden="true">
  <div class="shoreline-line"></div>
  <div class="shoreline-droplet">
    <svg viewBox="0 0 14 18" width="14" height="18" fill="none">
      <path d="M7 0 C 11 6, 14 11, 14 14 A 7 4 0 0 1 0 14 C 0 11, 3 6, 7 0 Z"
            fill="var(--color-bay-gold)" opacity="0.9"/>
      <ellipse cx="5" cy="11" rx="1.5" ry="2.5" fill="rgba(255,255,255,0.4)"/>
    </svg>
    <div class="shoreline-droplet-reflection"></div>
  </div>
</div>

<style>
  .shoreline-divider {
    position: relative;
    width: 100%;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shoreline-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(201,169,97,0.7) 30%, rgba(201,169,97,0.95) 50%, rgba(201,169,97,0.7) 70%, transparent 100%);
    box-shadow: 0 0 12px rgba(201,169,97,0.4), 0 0 32px rgba(201,169,97,0.15);
  }

  .shoreline-droplet {
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }

  .shoreline-droplet-reflection {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 6px;
    margin-top: 3px;
    background: radial-gradient(ellipse at center, rgba(201,169,97,0.35) 0%, transparent 70%);
    filter: blur(2px);
    pointer-events: none;
  }
</style>
