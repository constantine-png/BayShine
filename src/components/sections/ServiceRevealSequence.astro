---
// ServiceRevealSequence — scroll-driven horizontal pan of service cards.
// All cards visible simultaneously on desktop. Vertical scroll drives left-to-right pan.
import VideoLoop from '@/components/ui/VideoLoop.astro';
import { ASSET_REGISTRY } from '@/lib/assetRegistry';

const PANELS = [
  {
    id: 'exterior',
    number: '01',
    title: 'Exterior Detail',
    tagline: 'Paint and glass, correct sequence.',
    body: 'Two-bucket wash, clay decontamination, iron fallout removal, and a finishing spray sealant. Every panel inspected under lighting.',
    videoKey: 'showcaseExterior' as const,
    videoFile: 'showcase-exterior.mp4',
  },
  {
    id: 'full',
    number: '02',
    title: 'Full Detail',
    tagline: 'Interior and exterior in one visit.',
    body: 'Complete interior extraction, steam cleaning of contact surfaces, odor elimination, and the full exterior protocol.',
    videoKey: 'showcaseInterior' as const,
    videoFile: 'showcase-interior.mp4',
  },
  {
    id: 'decon',
    number: '03',
    title: 'Decontamination',
    tagline: 'Iron fallout and bonded contaminants. Removed.',
    body: 'Chemical decon spray, iron fallout remover, synthetic clay bar. The prep step that makes everything else last longer.',
    videoKey: 'showcaseDecon' as const,
    videoFile: 'showcase-decontamination.mp4',
  },
  {
    id: 'polish',
    number: '04',
    title: 'Paint Correction',
    tagline: 'Swirls and scratches. Not concealed – corrected.',
    body: 'Machine polishing with compound and finishing polish. Removes defects rather than filling them. Required before ceramic coating.',
    videoKey: 'showcasePolish' as const,
    videoFile: 'showcase-polish.mp4',
  },
  {
    id: 'coating',
    number: '05',
    title: 'Ceramic Coating',
    tagline: 'Semi-permanent protection.',
    body: '9H-hardness SiO₂ coating applied after paint correction. Hydrophobic, scratch-resistant, and slick under UV.',
    videoKey: 'showcaseCoating' as const,
    videoFile: 'showcase-coating.mp4',
  },
] as const;
---

<section class="sss-section">
  <!-- Normal-flow header: above the sticky scroll zone -->
  <div class="sss-header container mx-auto max-w-5xl px-4 pt-20 pb-10">
    <div class="reveal">
      <h2 class="font-display font-bold text-3xl text-bay-white mb-2">Services</h2>
      <p class="text-bay-slate text-sm">Every service is mobile. No drop-off, no waiting rooms.</p>
    </div>
  </div>

  <!-- Scroll runway: vertical height drives horizontal pan -->
  <div class="sss-outer">
    <div class="sss-sticky">
      <div class="sss-track" id="sss-track">
        {PANELS.map((panel) => (
          <article class="sss-card section-bevel" id={`sss-card-${panel.id}`}>
            {ASSET_REGISTRY[panel.videoKey] && (
              <div class="sss-card-video img-gloss" aria-hidden="true">
                <VideoLoop src={`/assets/video/${panel.videoFile}`} ariaLabel={panel.title} class="w-full h-full object-cover" />
              </div>
            )}
            <div class="sss-card-body">
              <span class="sss-card-number" aria-hidden="true">{panel.number}</span>
              <h3 class="sss-card-title">{panel.title}</h3>
              <p class="sss-card-tagline">{panel.tagline}</p>
              <p class="sss-card-desc">{panel.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .sss-section {
    overflow: hidden;
  }

  /* Normal-flow header stays above the sticky zone */
  .sss-header {
    position: relative;
    z-index: 1;
  }

  /* Scroll runway — 500vh creates the scroll budget for the pan */
  .sss-outer {
    height: 500vh;
    position: relative;
  }

  /* Sticky container pins to viewport during the 500vh scroll */
  .sss-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Horizontal card track — JS sets translateX */
  .sss-track {
    display: flex;
    gap: 1.5rem;
    padding: 0 5vw;
    will-change: transform;
  }

  /* Individual card */
  .sss-card {
    flex-shrink: 0;
    width: min(320px, 72vw);
    background-color: var(--color-bay-deep);
    border: 1px solid rgba(122,130,148,0.1);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Card video thumbnail */
  .sss-card-video {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-bay-navy);
  }

  .sss-card-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Card body */
  .sss-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Oversized outlined number */
  .sss-card-number {
    display: block;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(201,169,97,0.2);
    pointer-events: none;
    user-select: none;
    margin-bottom: 0.5rem;
    margin-left: -0.25rem;
  }

  .sss-card-title {
    font-family: var(--font-ui, 'Manrope', sans-serif);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-bay-white);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .sss-card-tagline {
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--color-bay-gold);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .sss-card-desc {
    color: var(--color-bay-slate);
    font-size: 0.75rem;
    line-height: 1.6;
    flex: 1;
  }

  /* Reduced motion: static horizontal row, no sticky scroll lock */
  @media (prefers-reduced-motion: reduce) {
    .sss-outer {
      height: auto;
    }
    .sss-sticky {
      position: static;
      height: auto;
      overflow: visible;
    }
    .sss-track {
      flex-wrap: wrap;
      transform: none !important;
    }
    .sss-card {
      flex: 1 1 280px;
    }
  }
</style>

<script>
  function initShowcaseScroll() {
    const outer = document.querySelector<HTMLElement>('.sss-outer');
    const track = document.getElementById('sss-track') as HTMLElement | null;
    if (!outer || !track) return;

    // Calculate pan range: track width minus viewport width plus padding buffer
    function getRange(): number {
      const trackW = track!.scrollWidth;
      const viewW = window.innerWidth;
      return Math.max(0, trackW - viewW + 160);
    }

    // Per-card easing: cubic in-out within each step, creating a brief center-hold per card
    function panEase(t: number, n: number): number {
      const step = 1 / n;
      const stepIndex = Math.min(n - 1, Math.floor(t / step));
      const local = (t - stepIndex * step) / step;
      const eased = local < 0.5
        ? 4 * local * local * local
        : 1 - Math.pow(-2 * local + 2, 3) / 2;
      return (stepIndex + eased) * step;
    }

    let rafId = 0;
    let lastX = Infinity;

    function update() {
      const outerRect = outer!.getBoundingClientRect();
      const totalScrollable = outerRect.height - window.innerHeight;
      if (totalScrollable <= 0) return;
      const scrolledInto = Math.max(0, -outerRect.top);
      const rawProgress = Math.min(1, scrolledInto / totalScrollable);

      const PANELS_COUNT = track!.querySelectorAll('.sss-card').length;
      const eased = panEase(rawProgress, PANELS_COUNT);

      const range = getRange();
      const cardEl = track!.querySelector('.sss-card') as HTMLElement | null;
      const cardW = cardEl?.offsetWidth ?? 320;
      const startOffset = (window.innerWidth - cardW) / 2 - 80;
      const translateX = startOffset - eased * (range + startOffset);

      if (Math.abs(translateX - lastX) > 0.5) {
        track!.style.transform = `translateX(${translateX}px)`;
        lastX = translateX;
      }
      rafId = 0;
    }

    function onScroll() {
      if (rafId) return;
      rafId = requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', update);
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShowcaseScroll);
  } else {
    initShowcaseScroll();
  }
</script>
