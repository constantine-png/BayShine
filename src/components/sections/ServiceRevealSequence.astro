---
// ServiceRevealSequence — per-card scroll-lock carousel. One card centered at a time.
// Scroll down advances cards; scroll up retreats. Last card releases to #standing-detail.
import VideoLoop from '@/components/ui/VideoLoop.astro';
import { ASSET_REGISTRY } from '@/lib/assetRegistry';

const PANELS = [
  { id: 'exterior', number: '01', title: 'Exterior Detail',   tagline: 'Paint and glass, correct sequence.',                body: 'Two-bucket wash, clay decontamination, iron fallout removal, and a finishing spray sealant. Every panel inspected under lighting.',      videoKey: 'showcaseExterior' as const, videoFile: 'showcase-exterior.mp4',        href: '/exterior-detail' },
  { id: 'full',     number: '02', title: 'Full Detail',        tagline: 'Interior and exterior in one visit.',              body: 'Complete interior extraction, steam cleaning of contact surfaces, odor elimination, and the full exterior protocol.',                    videoKey: 'showcaseInterior' as const, videoFile: 'showcase-interior.mp4',        href: '/full-detail' },
  { id: 'decon',    number: '03', title: 'Decontamination',    tagline: 'Iron fallout and bonded contaminants. Removed.',   body: 'Chemical decon spray, iron fallout remover, synthetic clay bar. The prep step that makes everything else last longer.',                  videoKey: 'showcaseDecon'   as const, videoFile: 'showcase-decontamination.mp4', href: '/exterior-detail' },
  { id: 'polish',   number: '04', title: 'Paint Correction',   tagline: 'Swirls and scratches. Not concealed – corrected.', body: 'Machine polishing with compound and finishing polish. Removes defects rather than filling them. Required before ceramic coating.', videoKey: 'showcasePolish'  as const, videoFile: 'showcase-polish.mp4',          href: '/recon' },
  { id: 'coating',  number: '05', title: 'Ceramic Coating',    tagline: 'Semi-permanent protection.',                       body: '9H-hardness SiO₂ coating applied after paint correction. Hydrophobic, scratch-resistant, and slick under UV.',                       videoKey: 'comparisonBayshine' as const, videoFile: 'comparison-bayshine-detail.mp4', href: '/ceramic-coating' },
  { id: 'fleet',      number: '06', title: 'Fleet Programs',        tagline: 'Throughput is the metric.',              body: 'Lot maintenance for 30 to 300+ vehicles. Standing schedule, per-unit pricing, monthly invoice.',           videoKey: 'ambientFleet' as const, videoFile: 'ambient-fleet.mp4',       href: '/fleet' },
  { id: 'apartments', number: '07', title: 'Property Programs',    tagline: 'A premium amenity. Zero cost to the property.', body: 'On-property detailing for resident communities. Residents enroll directly. The property adds the amenity — we handle everything else.', videoKey: 'ambientApts'  as const, videoFile: 'ambient-apartments.mp4', href: '/apartments' },
] as const;
---

<section class="srs-section" id="services" aria-label="Services">
  <!-- Card arena: 100vh, clips card overflow; header and tint live inside -->
  <div class="srs-arena" id="srs-arena">

    <!-- Section label: absolute, overlaid at top of arena -->
    <div class="srs-header" aria-hidden="false">
      <h2 class="font-display font-bold text-2xl text-bay-white mb-1">Services</h2>
      <p class="text-bay-slate text-xs tracking-wide">Every service is mobile. No drop-off, no waiting rooms.</p>
    </div>

    <!-- Amber glass tint overlay -->
    <div class="srs-tint" aria-hidden="true"></div>

    {PANELS.map((panel) => (
      <a
        href={panel.href}
        class="srs-card section-bevel"
        data-srs-card
        aria-label={panel.title}
      >
        {ASSET_REGISTRY[panel.videoKey] && (
          <div class="srs-card-video img-gloss" aria-hidden="true">
            <VideoLoop
              src={`/assets/video/${panel.videoFile}`}
              ariaLabel={panel.title}
              class="w-full h-full object-cover"
            />
          </div>
        )}
        <div class="srs-card-body">
          <span class="srs-card-number" aria-hidden="true">{panel.number}</span>
          <h3 class="srs-card-title">{panel.title}</h3>
          <p class="srs-card-tagline">{panel.tagline}</p>
          <p class="srs-card-desc">{panel.body}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  /* Section = arena exactly — no extra label above it */
  .srs-section {
    position: relative;
    /* No overflow, no height here — arena defines the height */
  }

  /* Arena is the full section: 100vh, clips card overflow */
  .srs-arena {
    position: relative;
    height: 100vh;
    overflow: hidden;
    /* Amber glass tint is rendered by .srs-tint below */
  }

  /* Header overlaid at top-center of the arena */
  .srs-header {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 20;
    white-space: nowrap;
    pointer-events: none;
  }

  /* Amber/sepia tint overlay — gives the section a warm glass feel */
  .srs-tint {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(201, 169, 97, 0.07) 0%, transparent 70%),
      linear-gradient(160deg, rgba(180, 110, 20, 0.05) 0%, rgba(201, 169, 97, 0.04) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Cards: absolute, JS controls transform */
  .srs-card {
    position: absolute;
    top: 50%;
    left: 0;
    width: min(400px, 84vw);
    background-color: var(--color-bay-deep);
    border: 1px solid rgba(122, 130, 148, 0.1);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    /* Initial state: off-screen right */
    transform: translateX(100vw) translateY(-50%) scale(0.9);
    opacity: 0;
    transition: transform 950ms cubic-bezier(0.16, 1, 0.3, 1), opacity 600ms ease-out, box-shadow 600ms ease-out;
    will-change: transform, opacity;
  }

  /* Active card gets gold box-shadow */
  .srs-card.is-active {
    box-shadow: 0 0 40px rgba(201, 169, 97, 0.15), 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .srs-card:focus-visible {
    outline: 2px solid var(--color-bay-gold);
    outline-offset: 3px;
  }

  .srs-card-video {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bay-navy);
    flex-shrink: 0;
  }

  .srs-card-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .srs-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .srs-card-number {
    display: block;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(201, 169, 97, 0.2);
    pointer-events: none;
    user-select: none;
    margin-bottom: 0.5rem;
    margin-left: -0.25rem;
  }

  .srs-card-title {
    font-family: var(--font-ui, 'Manrope', sans-serif);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-bay-white);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .srs-card-tagline {
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--color-bay-gold);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .srs-card-desc {
    color: var(--color-bay-slate);
    font-size: 0.75rem;
    line-height: 1.6;
    flex: 1;
  }

  /* Reduced motion: static flex row, no lock, no animations */
  @media (prefers-reduced-motion: reduce) {
    .srs-arena {
      height: auto;
      overflow: visible;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      padding: 2rem 1rem;
    }
    .srs-card {
      position: static;
      transform: none !important;
      opacity: 1 !important;
      flex: 1 1 280px;
      transition: none;
    }
  }
</style>

<script>
  function initServiceCards() {
    const arena = document.getElementById('srs-arena') as HTMLElement | null;
    if (!arena) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const cards = Array.from(arena.querySelectorAll<HTMLElement>('[data-srs-card]'));
    const N = cards.length;
    let activeIndex = 0;
    let isLocked = false;
    let isTransitioning = false;
    let wheelAcc = 0;
    let touchStartX = 0;
    let touchStartY = 0;

    // ── Positioning ──────────────────────────────────────────────────
    function positionAll(idx: number) {
      const vw = window.innerWidth;
      const cardW = (cards[0] as HTMLElement).offsetWidth || 320;
      const centerX = Math.round(vw / 2 - cardW / 2);

      cards.forEach((card, i) => {
        const offset = i - idx;
        let x: number, scale: number, opacity: number, zIndex: number;

        if (offset === 0) {
          x = centerX; scale = 1.07; opacity = 1; zIndex = 10;
          card.classList.add('is-active');
        } else if (offset < 0) {
          const d = -offset;
          x = centerX - d * Math.min(cardW * 0.5 + 20, 200);
          scale = Math.max(0.72, 0.9 - d * 0.07);
          opacity = Math.max(0.1, 0.5 - d * 0.15);
          zIndex = 10 - d;
          card.classList.remove('is-active');
        } else {
          x = vw + cardW + 40; scale = 0.9; opacity = 0; zIndex = 0;
          card.classList.remove('is-active');
        }

        card.style.transform = `translateX(${x}px) translateY(-50%) scale(${scale})`;
        card.style.opacity = String(opacity);
        card.style.zIndex = String(zIndex);
      });
    }

    // Show card 0 immediately — no waiting for lock, never invisible
    cards.forEach(c => { c.style.transition = 'none'; });
    positionAll(0);
    requestAnimationFrame(() => { cards.forEach(c => { c.style.transition = ''; }); });

    // ── Helpers ──────────────────────────────────────────────────────
    function getCardCenterX(): number {
      const vw = window.innerWidth;
      const cardW = (cards[0] as HTMLElement).offsetWidth || 320;
      return Math.round(vw / 2 - cardW / 2);
    }

    // Nudge the active card in `dir` then spring it back, then call onComplete.
    // dir: -1 = nudge left (exit-down feel), +1 = nudge right (exit-up feel).
    function bounceExit(dir: 1 | -1, onComplete: () => void) {
      isTransitioning = true;
      const card = cards[activeIndex] as HTMLElement;
      const cx = getCardCenterX();
      const nudge = dir * 52;

      // Phase 1 — quick nudge away from center
      card.style.transition = 'transform 170ms ease-out, opacity 170ms ease-out';
      card.style.transform = `translateX(${cx + nudge}px) translateY(-50%) scale(1.04)`;

      setTimeout(() => {
        // Phase 2 — spring back to active position (slight overshoot)
        card.style.transition = 'transform 420ms cubic-bezier(0.34, 1.56, 0.64, 1), opacity 250ms ease-out';
        card.style.transform = `translateX(${cx}px) translateY(-50%) scale(1.07)`;
        card.style.opacity = '1';

        setTimeout(() => {
          // Reset to the normal glide transition before releasing
          card.style.transition = '';
          isTransitioning = false;
          onComplete();
        }, 450);
      }, 180);
    }

    // ── Advance / retreat ────────────────────────────────────────────
    function advance() {
      if (isTransitioning) return;
      if (activeIndex < N - 1) {
        isTransitioning = true;
        activeIndex++;
        positionAll(activeIndex);
        setTimeout(() => { isTransitioning = false; }, 1000);
      } else {
        // Past last card: bounce back to center, then release downward
        bounceExit(-1, () => {
          unlock(true);
          requestAnimationFrame(() => {
            document.getElementById('standing-detail')
              ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        });
      }
    }

    function retreat() {
      if (isTransitioning) return;
      if (activeIndex > 0) {
        isTransitioning = true;
        activeIndex--;
        positionAll(activeIndex);
        setTimeout(() => { isTransitioning = false; }, 1000);
      } else {
        // Before first card: bounce back to center, then release upward
        bounceExit(1, () => {
          unlock(true);
        });
      }
    }

    // ── Input handlers ───────────────────────────────────────────────
    function onWheel(e: WheelEvent) {
      e.preventDefault();
      e.stopPropagation();
      // Drain momentum events during card transition — no bleed-through
      if (isTransitioning) { wheelAcc = 0; return; }
      // Normalize deltaMode: 0=pixels, 1=lines(~20px each), 2=pages(~300px)
      const raw = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
      const norm = e.deltaMode === 1 ? raw * 20 : e.deltaMode === 2 ? raw * 300 : raw;
      wheelAcc += norm;
      if (wheelAcc > 50) { wheelAcc = 0; advance(); }
      else if (wheelAcc < -50) { wheelAcc = 0; retreat(); }
    }

    function onTouchStart(e: TouchEvent) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }

    function onTouchMove(e: TouchEvent) {
      e.preventDefault();
      if (isTransitioning) return;
      const dx = touchStartX - e.touches[0].clientX;
      const dy = touchStartY - e.touches[0].clientY;
      const delta = Math.abs(dx) >= Math.abs(dy) ? dx : dy;
      if (Math.abs(delta) > 40) {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        if (delta > 0) advance(); else retreat();
      }
    }

    // ── Lock / unlock ────────────────────────────────────────────────
    // exitSuppressed: blocks re-lock for 900ms after intentional exit so the
    // IntersectionObserver can't fire lock() before scrollIntoView moves the page away
    let exitSuppressed = false;

    function unlock(suppressReentry = false) {
      if (!isLocked) return;
      isLocked = false;
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
      window.removeEventListener('wheel', onWheel);
      window.removeEventListener('touchstart', onTouchStart);
      window.removeEventListener('touchmove', onTouchMove);
      if (suppressReentry) {
        exitSuppressed = true;
        setTimeout(() => { exitSuppressed = false; }, 900);
      }
    }

    // ── Smooth center-scroll animation ──────────────────────────────
    // Animates window scroll to targetY with ease-out-cubic, then calls onDone.
    // Running this BEFORE setting overflow:hidden is the key fix — some browsers
    // silently ignore window.scrollTo after overflow:hidden is applied to body.
    function scrollToCenter(targetY: number, duration: number, onDone: () => void) {
      const startY = window.scrollY;
      const dist   = targetY - startY;
      if (Math.abs(dist) < 2) { onDone(); return; }

      const t0 = performance.now();
      function tick(now: number) {
        const t = Math.min((now - t0) / duration, 1);
        const ease = 1 - Math.pow(1 - t, 3); // ease-out cubic
        window.scrollTo(0, Math.round(startY + dist * ease));
        if (t < 1) requestAnimationFrame(tick);
        else onDone();
      }
      requestAnimationFrame(tick);
    }

    // ── Lock: slide arena to center, then hand off to card nav ──────
    let isSnapping = false;

    function lock(enteringFromBelow: boolean) {
      if (isLocked || isSnapping) return;
      isSnapping = true;
      wheelAcc = 0;

      // Compensate for scrollbar disappearance on Windows/Linux
      const scrollbarW = window.innerWidth - document.documentElement.clientWidth;
      if (scrollbarW > 0) document.body.style.paddingRight = `${scrollbarW}px`;

      // Block user scroll input during the slide animation so the programmatic
      // scroll is never interrupted. capture:true intercepts before page handlers.
      function blockInput(e: Event) { e.preventDefault(); e.stopPropagation(); }
      window.addEventListener('wheel',     blockInput, { passive: false, capture: true });
      window.addEventListener('touchmove', blockInput, { passive: false, capture: true });

      // Target: arena top aligned with viewport top. Since arena is 100vh this
      // fills the viewport and vertically centers the cards (top:50% translateY(-50%)).
      const rect    = arena!.getBoundingClientRect();
      const targetY = Math.round(window.scrollY + rect.top);

      // Smooth deceleration slide into position (550ms ease-out-cubic)
      scrollToCenter(targetY, 550, () => {
        window.removeEventListener('wheel',     blockInput, { capture: true });
        window.removeEventListener('touchmove', blockInput, { capture: true });

        // Freeze AFTER the scroll has landed — this is why it centers correctly now
        document.body.style.overflow = 'hidden';
        wheelAcc = 0;

        setTimeout(() => {
          isSnapping = false;
          isLocked   = true;
          wheelAcc   = 0;

          const startIndex = enteringFromBelow ? 0 : N - 1;
          if (startIndex !== activeIndex) {
            cards.forEach(c => { c.style.transition = 'none'; });
            activeIndex = startIndex;
            positionAll(activeIndex);
            requestAnimationFrame(() => { cards.forEach(c => { c.style.transition = ''; }); });
          }

          window.addEventListener('wheel',      onWheel,      { passive: false });
          window.addEventListener('touchstart', onTouchStart, { passive: true });
          window.addEventListener('touchmove',  onTouchMove,  { passive: false });
        }, 50);
      });
    }

    // ── IntersectionObserver: fire at 20% so we catch users before momentum builds ───
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && entry.intersectionRatio >= 0.2) {
          if (!isLocked && !isSnapping && !exitSuppressed) {
            const enteringFromBelow = entry.boundingClientRect.top >= 0;
            lock(enteringFromBelow);
          }
        } else if (!entry.isIntersecting) {
          if (isLocked) unlock();
          isSnapping = false;
        }
      });
    }, { threshold: [0, 0.2, 0.5] });

    observer.observe(arena!);

    window.addEventListener('resize', () => {
      if (isLocked) positionAll(activeIndex);
    }, { passive: true });

    document.addEventListener('astro:before-swap', () => {
      unlock();
      isSnapping = false;
      observer.disconnect();
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServiceCards);
  } else {
    initServiceCards();
  }
</script>
