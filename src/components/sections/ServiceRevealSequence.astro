---
// ServiceRevealSequence — per-card scroll-lock carousel. One card centered at a time.
// Scroll down advances cards; scroll up retreats. Last card releases to #standing-detail.
import VideoLoop from '@/components/ui/VideoLoop.astro';
import { ASSET_REGISTRY } from '@/lib/assetRegistry';

const PANELS = [
  { id: 'exterior', number: '01', title: 'Exterior Detail',   tagline: 'Paint and glass, correct sequence.',                body: 'Two-bucket wash, clay decontamination, iron fallout removal, and a finishing spray sealant. Every panel inspected under lighting.',      videoKey: 'showcaseExterior' as const, videoFile: 'showcase-exterior.mp4',        href: '/exterior-detail' },
  { id: 'full',     number: '02', title: 'Full Detail',        tagline: 'Interior and exterior in one visit.',              body: 'Complete interior extraction, steam cleaning of contact surfaces, odor elimination, and the full exterior protocol.',                    videoKey: 'showcaseInterior' as const, videoFile: 'showcase-interior.mp4',        href: '/full-detail' },
  { id: 'decon',    number: '03', title: 'Decontamination',    tagline: 'Iron fallout and bonded contaminants. Removed.',   body: 'Chemical decon spray, iron fallout remover, synthetic clay bar. The prep step that makes everything else last longer.',                  videoKey: 'showcaseDecon'   as const, videoFile: 'showcase-decontamination.mp4', href: '/exterior-detail' },
  { id: 'polish',   number: '04', title: 'Paint Correction',   tagline: 'Swirls and scratches. Not concealed – corrected.', body: 'Machine polishing with compound and finishing polish. Removes defects rather than filling them. Required before ceramic coating.', videoKey: 'showcasePolish'  as const, videoFile: 'showcase-polish.mp4',          href: '/recon' },
  { id: 'coating',  number: '05', title: 'Ceramic Coating',    tagline: 'Semi-permanent protection.',                       body: '9H-hardness SiO₂ coating applied after paint correction. Hydrophobic, scratch-resistant, and slick under UV.',                       videoKey: 'showcaseCoating' as const, videoFile: 'showcase-coating.mp4',         href: '/ceramic-coating' },
] as const;
---

<section class="srs-section" id="services" aria-label="Services">
  <!-- Section label: normal flow, above the lock zone -->
  <div class="container mx-auto max-w-5xl px-4 pt-20 pb-8 reveal">
    <h2 class="font-display font-bold text-3xl text-bay-white mb-2">Services</h2>
    <p class="text-bay-slate text-sm">Every service is mobile. No drop-off, no waiting rooms.</p>
  </div>

  <!-- Card arena: 100vh, cards positioned absolutely by JS -->
  <div class="srs-arena" id="srs-arena">
    {PANELS.map((panel) => (
      <a
        href={panel.href}
        class="srs-card section-bevel"
        data-srs-card
        aria-label={panel.title}
      >
        {ASSET_REGISTRY[panel.videoKey] && (
          <div class="srs-card-video img-gloss" aria-hidden="true">
            <VideoLoop
              src={`/assets/video/${panel.videoFile}`}
              ariaLabel={panel.title}
              class="w-full h-full object-cover"
            />
          </div>
        )}
        <div class="srs-card-body">
          <span class="srs-card-number" aria-hidden="true">{panel.number}</span>
          <h3 class="srs-card-title">{panel.title}</h3>
          <p class="srs-card-tagline">{panel.tagline}</p>
          <p class="srs-card-desc">{panel.body}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  /* Section wrapper — NO overflow:hidden (would break sticky) */
  .srs-section {
    position: relative;
  }

  /* Card arena: full viewport height, clips cards during animation */
  .srs-arena {
    position: relative;
    height: 100vh;
    overflow: hidden; /* clips overflow only on the inner arena, not the outer section */
  }

  /* Cards: absolute, JS controls transform */
  .srs-card {
    position: absolute;
    top: 50%;
    left: 0;
    width: min(320px, 78vw);
    background-color: var(--color-bay-deep);
    border: 1px solid rgba(122, 130, 148, 0.1);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    /* Initial state: off-screen right */
    transform: translateX(100vw) translateY(-50%) scale(0.9);
    opacity: 0;
    transition: transform 550ms ease-out, opacity 350ms ease-out, box-shadow 350ms ease-out;
    will-change: transform, opacity;
  }

  /* Active card gets gold box-shadow */
  .srs-card.is-active {
    box-shadow: 0 0 40px rgba(201, 169, 97, 0.15), 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .srs-card:focus-visible {
    outline: 2px solid var(--color-bay-gold);
    outline-offset: 3px;
  }

  .srs-card-video {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bay-navy);
    flex-shrink: 0;
  }

  .srs-card-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .srs-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .srs-card-number {
    display: block;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(201, 169, 97, 0.2);
    pointer-events: none;
    user-select: none;
    margin-bottom: 0.5rem;
    margin-left: -0.25rem;
  }

  .srs-card-title {
    font-family: var(--font-ui, 'Manrope', sans-serif);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-bay-white);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .srs-card-tagline {
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--color-bay-gold);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .srs-card-desc {
    color: var(--color-bay-slate);
    font-size: 0.75rem;
    line-height: 1.6;
    flex: 1;
  }

  /* Reduced motion: static flex row, no lock, no animations */
  @media (prefers-reduced-motion: reduce) {
    .srs-arena {
      height: auto;
      overflow: visible;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      padding: 2rem 1rem;
    }
    .srs-card {
      position: static;
      transform: none !important;
      opacity: 1 !important;
      flex: 1 1 280px;
      transition: none;
    }
  }
</style>

<script>
  function initServiceCards() {
    const section = document.getElementById('services') as HTMLElement | null;
    const arena = document.getElementById('srs-arena') as HTMLElement | null;
    if (!section || !arena) return;

    // Skip if reduced-motion preference
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const cards = Array.from(arena.querySelectorAll<HTMLElement>('[data-srs-card]'));
    const N = cards.length;
    let activeIndex = 0;
    let isLocked = false;
    let isTransitioning = false;
    let wheelAccumulator = 0;
    let touchStartY = 0;

    // ---------- Card positioning ----------

    function positionAll(index: number) {
      const vw = window.innerWidth;
      const cardW = cards[0]?.offsetWidth ?? 320;
      const centerX = vw / 2 - cardW / 2;

      cards.forEach((card, i) => {
        const offset = i - index;
        let x: number, scale: number, opacity: number, zIndex: number;

        if (offset === 0) {
          x = centerX;
          scale = 1.07;
          opacity = 1;
          zIndex = 10;
          card.classList.add('is-active');
        } else if (offset < 0) {
          const depth = -offset;
          // Stack to the left: each past card moves further left and shrinks
          x = centerX - depth * Math.min(cardW * 0.55 + 16, 200);
          scale = Math.max(0.72, 0.9 - depth * 0.07);
          opacity = Math.max(0.1, 0.55 - depth * 0.18);
          zIndex = 10 - depth;
          card.classList.remove('is-active');
        } else {
          // Future cards: off-screen right
          x = vw + cardW + 40;
          scale = 0.9;
          opacity = 0;
          zIndex = 0;
          card.classList.remove('is-active');
        }

        card.style.transform = `translateX(${x}px) translateY(-50%) scale(${scale})`;
        card.style.opacity = String(opacity);
        card.style.zIndex = String(zIndex);
      });
    }

    // ---------- Advance / retreat ----------

    function advance() {
      if (isTransitioning) return;
      if (activeIndex < N - 1) {
        isTransitioning = true;
        activeIndex++;
        positionAll(activeIndex);
        setTimeout(() => { isTransitioning = false; }, 600);
      } else {
        // Last card — release and scroll to Standing Detail
        unlock();
        requestAnimationFrame(() => {
          document.getElementById('standing-detail')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    }

    function retreat() {
      if (isTransitioning) return;
      if (activeIndex > 0) {
        isTransitioning = true;
        activeIndex--;
        positionAll(activeIndex);
        setTimeout(() => { isTransitioning = false; }, 600);
      } else {
        // First card — release and allow upward scroll
        unlock();
      }
    }

    // ---------- Event handlers ----------

    function onWheel(e: WheelEvent) {
      e.preventDefault();
      e.stopPropagation();
      wheelAccumulator += e.deltaY;
      if (wheelAccumulator > 60) { wheelAccumulator = 0; advance(); }
      else if (wheelAccumulator < -60) { wheelAccumulator = 0; retreat(); }
    }

    function onTouchStart(e: TouchEvent) {
      touchStartY = e.touches[0].clientY;
    }

    function onTouchMove(e: TouchEvent) {
      e.preventDefault();
      const dy = touchStartY - e.touches[0].clientY;
      if (Math.abs(dy) > 40) {
        touchStartY = e.touches[0].clientY;
        if (dy > 0) advance(); else retreat();
      }
    }

    // ---------- Lock / unlock ----------

    function lock(fromBottom: boolean = false) {
      if (isLocked) return;
      isLocked = true;
      wheelAccumulator = 0;
      activeIndex = fromBottom ? N - 1 : 0;
      positionAll(activeIndex);
      window.addEventListener('wheel', onWheel, { passive: false });
      window.addEventListener('touchstart', onTouchStart, { passive: false });
      window.addEventListener('touchmove', onTouchMove, { passive: false });
    }

    function unlock() {
      if (!isLocked) return;
      isLocked = false;
      window.removeEventListener('wheel', onWheel);
      window.removeEventListener('touchstart', onTouchStart);
      window.removeEventListener('touchmove', onTouchMove);
    }

    // ---------- Scroll listener: detect when arena fills viewport ----------

    let lastScrollY = window.scrollY;
    let scrollRafId = 0;

    function checkEntry() {
      const rect = arena!.getBoundingClientRect();
      const vh = window.innerHeight;
      const scrollingDown = window.scrollY >= lastScrollY;
      lastScrollY = window.scrollY;

      if (!isLocked) {
        // Lock when the arena sits flush at the viewport top
        if (rect.top <= 2 && rect.top >= -vh * 0.05 && rect.bottom >= vh - 2) {
          lock(!scrollingDown);
        }
      }
      scrollRafId = 0;
    }

    function onPageScroll() {
      lastScrollY = window.scrollY;
      if (scrollRafId) return;
      scrollRafId = requestAnimationFrame(checkEntry);
    }

    window.addEventListener('scroll', onPageScroll, { passive: true });
    window.addEventListener('resize', () => { if (isLocked) positionAll(activeIndex); }, { passive: true });

    // Initialize all cards off-screen right
    function initPositions() {
      const vw = window.innerWidth;
      cards.forEach(card => {
        const cardW = card.offsetWidth || 320;
        card.style.transform = `translateX(${vw + cardW + 40}px) translateY(-50%) scale(0.9)`;
        card.style.opacity = '0';
        card.style.zIndex = '0';
        card.style.transition = 'none'; // no animation on init
      });
      // Re-enable transitions after one frame
      requestAnimationFrame(() => {
        cards.forEach(card => { card.style.transition = ''; });
      });
    }

    initPositions();
    checkEntry();

    document.addEventListener('astro:before-swap', () => {
      unlock();
      window.removeEventListener('scroll', onPageScroll);
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServiceCards);
  } else {
    initServiceCards();
  }
</script>
