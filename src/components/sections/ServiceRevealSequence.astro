---
// ServiceRevealSequence — sticky scroll-driven carousel.
// A tall scroll tunnel makes the arena position:sticky so it pins to the
// viewport top. As the user scrolls through the tunnel, scroll progress maps
// to which card is active. No scroll locking, no body manipulation.
import VideoLoop from '@/components/ui/VideoLoop.astro';
import { ASSET_REGISTRY } from '@/lib/assetRegistry';

const PANELS = [
  { id: 'exterior', number: '01', title: 'Exterior Detail',   tagline: 'Paint and glass, correct sequence.',                body: 'Two-bucket wash, clay decontamination, iron fallout removal, and a finishing spray sealant. Every panel inspected under lighting.',      videoKey: 'showcaseExterior' as const, videoFile: 'showcase-exterior.mp4',        href: '/exterior-detail' },
  { id: 'full',     number: '02', title: 'Full Detail',        tagline: 'Interior and exterior in one visit.',              body: 'Complete interior extraction, steam cleaning of contact surfaces, odor elimination, and the full exterior protocol.',                    videoKey: 'showcaseInterior' as const, videoFile: 'showcase-interior.mp4',        href: '/full-detail' },
  { id: 'decon',    number: '03', title: 'Decontamination',    tagline: 'Iron fallout and bonded contaminants. Removed.',   body: 'Chemical decon spray, iron fallout remover, synthetic clay bar. The prep step that makes everything else last longer.',                  videoKey: 'showcaseDecon'   as const, videoFile: 'showcase-decontamination.mp4', href: '/exterior-detail' },
  { id: 'polish',   number: '04', title: 'Paint Correction',   tagline: 'Swirls and scratches. Not concealed – corrected.', body: 'Machine polishing with compound and finishing polish. Removes defects rather than filling them. Required before ceramic coating.', videoKey: 'showcasePolish'  as const, videoFile: 'showcase-polish.mp4',          href: '/recon' },
  { id: 'coating',  number: '05', title: 'Ceramic Coating',    tagline: 'Semi-permanent protection.',                       body: '9H-hardness SiO₂ coating applied after paint correction. Hydrophobic, scratch-resistant, and slick under UV.',                       videoKey: 'comparisonBayshine' as const, videoFile: 'comparison-bayshine-detail.mp4', href: '/ceramic-coating' },
  { id: 'fleet',    number: '06', title: 'Fleet Programs',     tagline: 'Throughput is the metric.',                        body: 'Lot maintenance for 30 to 300+ vehicles. Standing schedule, per-unit pricing, monthly invoice.',                                        videoKey: 'ambientFleet' as const, videoFile: 'ambient-fleet.mp4',               href: '/fleet' },
  { id: 'apartments', number: '07', title: 'Property Programs', tagline: 'A premium amenity. Zero cost to the property.',  body: 'On-property detailing for resident communities. Residents enroll directly. The property adds the amenity — we handle everything else.', videoKey: 'ambientApts'  as const, videoFile: 'ambient-apartments.mp4',          href: '/apartments' },
] as const;

const N = PANELS.length;
---

<section class="srs-section" id="services" aria-label="Services">
  <!--
    Scroll tunnel: tall enough to give each card its own dwell zone.
    The arena is position:sticky inside — it pins to the top of the
    viewport while the user scrolls through the tunnel.
  -->
  <div class="srs-tunnel" id="srs-tunnel">
    <div class="srs-arena" id="srs-arena">

      <!-- Section label overlaid at top of arena -->
      <div class="srs-header" aria-hidden="false">
        <h2 class="font-display font-bold text-2xl text-bay-white mb-1">Services</h2>
        <p class="text-bay-slate text-xs tracking-wide">Every service is mobile. No drop-off, no waiting rooms.</p>
      </div>

      <!-- Amber glass tint overlay -->
      <div class="srs-tint" aria-hidden="true"></div>

      {PANELS.map((panel) => (
        <a
          href={panel.href}
          class="srs-card section-bevel"
          data-srs-card
          aria-label={panel.title}
        >
          {ASSET_REGISTRY[panel.videoKey] && (
            <div class="srs-card-video img-gloss" aria-hidden="true">
              <VideoLoop
                src={`/assets/video/${panel.videoFile}`}
                ariaLabel={panel.title}
                class="w-full h-full object-cover"
              />
            </div>
          )}
          <div class="srs-card-body">
            <span class="srs-card-number" aria-hidden="true">{panel.number}</span>
            <h3 class="srs-card-title">{panel.title}</h3>
            <p class="srs-card-tagline">{panel.tagline}</p>
            <p class="srs-card-desc">{panel.body}</p>
          </div>
        </a>
      ))}

    </div>
  </div>
</section>

<style define:vars={{ N }}>
  .srs-section {
    position: relative;
  }

  /*
    Scroll tunnel: sets total dwell time for the carousel.
    Each card gets one viewport-height of scroll travel, plus one extra
    viewport at the end so the last card clears cleanly.
  */
  .srs-tunnel {
    height: calc((var(--N) + 1) * 100vh);
    position: relative;
  }

  /*
    Arena: sticky, pins to top of viewport as tunnel scrolls past.
    Cards inside are absolute at top:50% translateY(-50%) so they're
    always centered within the 100vh arena = centered in the viewport.
  */
  .srs-arena {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
  }

  /* Section label: absolute, overlaid at top of arena */
  .srs-header {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 20;
    white-space: nowrap;
    pointer-events: none;
  }

  /* Amber glass tint overlay */
  .srs-tint {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(201, 169, 97, 0.07) 0%, transparent 70%),
      linear-gradient(160deg, rgba(180, 110, 20, 0.05) 0%, rgba(201, 169, 97, 0.04) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Cards: absolute, JS controls transform */
  .srs-card {
    position: absolute;
    top: 50%;
    left: 0;
    width: min(400px, 84vw);
    background-color: var(--color-bay-deep);
    border: 1px solid rgba(122, 130, 148, 0.1);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    /* Initial state: off-screen right */
    transform: translateX(100vw) translateY(-50%) scale(0.9);
    opacity: 0;
    transition: transform 950ms cubic-bezier(0.16, 1, 0.3, 1), opacity 600ms ease-out, box-shadow 600ms ease-out;
    will-change: transform, opacity;
  }

  /* Active card gets gold box-shadow */
  .srs-card.is-active {
    box-shadow: 0 0 40px rgba(201, 169, 97, 0.15), 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .srs-card:focus-visible {
    outline: 2px solid var(--color-bay-gold);
    outline-offset: 3px;
  }

  .srs-card-video {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bay-navy);
    flex-shrink: 0;
  }

  .srs-card-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .srs-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .srs-card-number {
    display: block;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(201, 169, 97, 0.2);
    pointer-events: none;
    user-select: none;
    margin-bottom: 0.5rem;
    margin-left: -0.25rem;
  }

  .srs-card-title {
    font-family: var(--font-ui, 'Manrope', sans-serif);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-bay-white);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .srs-card-tagline {
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: var(--color-bay-gold);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .srs-card-desc {
    color: var(--color-bay-slate);
    font-size: 0.75rem;
    line-height: 1.6;
    flex: 1;
  }

  /* Reduced motion: static grid, no sticky, no animations */
  @media (prefers-reduced-motion: reduce) {
    .srs-tunnel {
      height: auto;
    }
    .srs-arena {
      position: static;
      height: auto;
      overflow: visible;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      padding: 2rem 1rem;
    }
    .srs-card {
      position: static;
      transform: none !important;
      opacity: 1 !important;
      flex: 1 1 280px;
      transition: none;
    }
  }
</style>

<script>
  function initServiceCards() {
    const tunnel = document.getElementById('srs-tunnel') as HTMLElement | null;
    const arena  = document.getElementById('srs-arena') as HTMLElement | null;
    if (!tunnel || !arena) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const cards = Array.from(arena.querySelectorAll<HTMLElement>('[data-srs-card]'));
    const N = cards.length;
    let activeIndex = -1;

    // ── Card positioning ─────────────────────────────────────────────
    function positionAll(idx: number) {
      const vw    = window.innerWidth;
      const cardW = (cards[0] as HTMLElement).offsetWidth || 320;
      const centerX = Math.round(vw / 2 - cardW / 2);

      cards.forEach((card, i) => {
        const offset = i - idx;
        let x: number, scale: number, opacity: number, zIndex: number;

        if (offset === 0) {
          x = centerX; scale = 1.07; opacity = 1; zIndex = 10;
          card.classList.add('is-active');
        } else if (offset < 0) {
          const d = -offset;
          x = centerX - d * Math.min(cardW * 0.5 + 20, 200);
          scale = Math.max(0.72, 0.9 - d * 0.07);
          opacity = Math.max(0.1, 0.5 - d * 0.15);
          zIndex = 10 - d;
          card.classList.remove('is-active');
        } else {
          x = vw + cardW + 40; scale = 0.9; opacity = 0; zIndex = 0;
          card.classList.remove('is-active');
        }

        card.style.transform = `translateX(${x}px) translateY(-50%) scale(${scale})`;
        card.style.opacity   = String(opacity);
        card.style.zIndex    = String(zIndex);
      });
    }

    // ── Scroll-progress → card index ─────────────────────────────────
    // Maps how far the user has scrolled through the tunnel (0–1) to a
    // card index (0 to N-1). Each card gets an equal slice of the tunnel.
    function getScrollIndex(): number {
      const rect        = tunnel!.getBoundingClientRect();
      const scrolled    = Math.max(0, -rect.top);                       // px into tunnel
      const totalTravel = Math.max(1, rect.height - window.innerHeight); // scrollable range
      const progress    = Math.min(1, scrolled / totalTravel);
      return Math.min(N - 1, Math.floor(progress * N));
    }

    // Initial render without transition flash
    const initIdx = getScrollIndex();
    cards.forEach(c => { c.style.transition = 'none'; });
    positionAll(initIdx);
    activeIndex = initIdx;
    requestAnimationFrame(() => { cards.forEach(c => { c.style.transition = ''; }); });

    // ── Scroll listener ──────────────────────────────────────────────
    function onScroll() {
      const newIndex = getScrollIndex();
      if (newIndex !== activeIndex) {
        activeIndex = newIndex;
        positionAll(activeIndex);
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { positionAll(activeIndex); }, { passive: true });

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServiceCards);
  } else {
    initServiceCards();
  }
</script>
