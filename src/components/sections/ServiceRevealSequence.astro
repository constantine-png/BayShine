---
// ServiceRevealSequence — sticky 600vh scroll runway presenting one service panel at a time,
// ending with an all-services row. No dots, no carousel. Pure scroll-driven reveal.
import VideoLoop from '@/components/ui/VideoLoop.astro';
import { ASSET_REGISTRY } from '@/lib/assetRegistry';

const SERVICES = [
  {
    id: 'interior',
    title: 'Full Detail',
    tagline: 'Interior and exterior. Left cleaner than factory.',
    videoKey: 'showcaseInterior' as const,
    videoFile: 'showcase-interior.mp4',
  },
  {
    id: 'exterior',
    title: 'Exterior Detail',
    tagline: 'Paint and glass, correct sequence.',
    videoKey: 'showcaseExterior' as const,
    videoFile: 'showcase-exterior.mp4',
  },
  {
    id: 'decon',
    title: 'Decontamination',
    tagline: 'Iron fallout, bonded contaminants. Removed.',
    videoKey: 'showcaseDecon' as const,
    videoFile: 'showcase-decontamination.mp4',
  },
  {
    id: 'polish',
    title: 'Paint Correction',
    tagline: 'Swirls and scratches. Not concealed – corrected.',
    videoKey: 'showcasePolish' as const,
    videoFile: 'showcase-polish.mp4',
  },
  {
    id: 'coating',
    title: 'Ceramic Coating',
    tagline: 'Semi-permanent protection. 2 to 5 years under Tampa Bay sun.',
    videoKey: 'showcaseCoating' as const,
    videoFile: 'showcase-coating.mp4',
  },
] as const;
---

<!-- Section heading above the scroll runway (normal flow, always visible) -->
<div class="srs-header container mx-auto max-w-5xl px-4 py-20">
  <h2>Services</h2>
  <p>Every service is mobile. No drop-off, no waiting rooms.</p>
</div>

<!-- 600vh scroll runway + sticky container -->
<div class="srs-outer" aria-label="Service reveal sequence">
  <div class="srs-sticky" aria-live="polite">

    <!-- Single-service panels (one per service, only one visible at a time) -->
    {SERVICES.map((svc, i) => (
      <div class="srs-panel" data-index={i} aria-hidden={i !== 0 ? 'true' : 'false'}>
        <!-- Background video at 60% opacity -->
        {ASSET_REGISTRY[svc.videoKey] && (
          <VideoLoop src={`/assets/video/${svc.videoFile}`} ariaLabel={svc.title} class="srs-video" />
        )}
        <!-- Overlay gradient -->
        <div class="srs-panel-overlay" aria-hidden="true"></div>
        <!-- Content -->
        <div class="srs-panel-content">
          <h3 class="srs-service-title">{svc.title}</h3>
          <p class="srs-service-tagline">{svc.tagline}</p>
        </div>
      </div>
    ))}

    <!-- All-services row (shown during final 16.6% of scroll) -->
    <div class="srs-row" aria-hidden="true">
      {SERVICES.map((svc) => (
        <div class="srs-row-card">
          {ASSET_REGISTRY[svc.videoKey] && (
            <VideoLoop src={`/assets/video/${svc.videoFile}`} ariaLabel={svc.title} class="srs-row-video" />
          )}
          <div class="srs-row-card-content">
            <p class="srs-row-title">{svc.title}</p>
            <p class="srs-row-tagline">{svc.tagline}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</div>

<style>
  /* Heading above the scroll runway */
  .srs-header h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    color: var(--color-bay-white);
    margin-bottom: 0.5rem;
  }
  .srs-header p {
    color: var(--color-bay-slate);
    font-size: 0.875rem;
  }

  /* 600vh outer container — creates scroll runway */
  .srs-outer {
    position: relative;
    height: 600vh;
  }

  /* Sticky inner — stays in viewport during 600vh scroll */
  .srs-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
  }

  /* Individual service panels */
  .srs-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 100ms ease-out;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .srs-panel.is-active {
    opacity: 1;
  }

  /* Panel background video */
  .srs-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
  }
  /* VideoLoop renders a <video> tag, so also target that */
  .srs-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Gradient overlay darkening the video */
  .srs-panel-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 18, 32, 0.85) 0%, rgba(10, 18, 32, 0.4) 50%, rgba(10, 18, 32, 0.2) 100%);
  }

  /* Panel content — centered text */
  .srs-panel-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
    max-width: 640px;
  }

  .srs-service-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5rem);
    color: var(--color-bay-white);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .srs-service-tagline {
    font-size: 1rem;
    color: var(--color-bay-gold);
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  /* All-services row */
  .srs-row {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 100ms ease-out;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
    background: var(--color-bay-deep);
  }
  .srs-row.is-active {
    opacity: 1;
  }

  .srs-row-card {
    flex: 1;
    min-width: 0;
    position: relative;
    height: 60vh;
    overflow: hidden;
    border-radius: 2px;
  }

  .srs-row-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
  }
  .srs-row-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .srs-row-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(10,18,32,0.9) 0%, transparent 100%);
  }

  .srs-row-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-bay-white);
    margin-bottom: 0.25rem;
  }

  .srs-row-tagline {
    font-size: 0.7rem;
    color: var(--color-bay-slate);
    line-height: 1.4;
  }

  /* Mobile: all-services row becomes vertical stack */
  @media (max-width: 768px) {
    .srs-row {
      flex-direction: column;
      gap: 0.75rem;
      overflow-y: auto;
      align-items: stretch;
    }
    .srs-row-card {
      height: 25vw;
      min-height: 100px;
      flex: none;
    }
  }

  /* Reduced motion: collapse to static all-services row, no scroll-lock behavior */
  @media (prefers-reduced-motion: reduce) {
    .srs-outer {
      height: auto;
    }
    .srs-sticky {
      position: static;
      height: auto;
    }
    .srs-panel {
      display: none;
    }
    .srs-row {
      position: static;
      opacity: 1;
      height: auto;
      flex-wrap: wrap;
    }
    .srs-row-card {
      height: 200px;
      flex: 0 0 calc(50% - 0.5rem);
    }
  }
</style>

<script>
  function initServiceReveal() {
    const outer = document.querySelector<HTMLElement>('.srs-outer');
    const sticky = document.querySelector<HTMLElement>('.srs-sticky');
    if (!outer || !sticky) return;

    const panels = Array.from(sticky.querySelectorAll<HTMLElement>('.srs-panel'));
    const row = sticky.querySelector<HTMLElement>('.srs-row');
    const SERVICES_COUNT = panels.length; // 5
    const STEP = 1 / (SERVICES_COUNT + 1); // 1/6 ≈ 0.1666...
    const ROW_THRESHOLD = SERVICES_COUNT * STEP; // 5/6 ≈ 0.8333...

    let rafId = 0;
    let lastActive = -1;
    let lastShowRow = false;

    function update() {
      const outerRect = outer!.getBoundingClientRect();
      const totalScrollable = outerRect.height - window.innerHeight;
      if (totalScrollable <= 0) return;
      const scrolledInto = Math.max(0, -outerRect.top);
      const progress = Math.min(1, scrolledInto / totalScrollable);

      const showRow = progress >= ROW_THRESHOLD;
      const activeIndex = showRow ? -1 : Math.min(SERVICES_COUNT - 1, Math.floor(progress / STEP));

      if (activeIndex !== lastActive || showRow !== lastShowRow) {
        panels.forEach((p, i) => {
          const active = i === activeIndex;
          p.classList.toggle('is-active', active);
          p.setAttribute('aria-hidden', String(!active));
        });
        if (row) {
          row.classList.toggle('is-active', showRow);
          row.setAttribute('aria-hidden', String(!showRow));
        }
        lastActive = activeIndex;
        lastShowRow = showRow;
      }
      rafId = 0;
    }

    function onScroll() {
      if (rafId) return;
      rafId = requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', update);
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServiceReveal);
  } else {
    initServiceReveal();
  }
</script>
