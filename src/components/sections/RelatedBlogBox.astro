---
// RelatedBlogBox: in-page reader. Full post content in a scrollable panel;
// other posts in the topic listed below as switcher buttons — no navigation needed.
import { getCollection } from 'astro:content';

interface Props {
  topic: string;
}

const { topic } = Astro.props;

const all = await getCollection('blog');
const matched = all
  .filter(p => p.data.serviceTopic === topic && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

if (matched.length === 0) return;

const rendered = await Promise.all(matched.map(p => p.render()));

// Stable UID so JS can scope to this instance without conflicts
const uid = `sfg-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="sfg-hairline" aria-hidden="true"></div>

<section class="sfg-section" aria-label="From the Field Guide">
  <div class="sfg-card noise-overlay" data-sfg-uid={uid}>

    <p class="sfg-eyebrow">From the Field Guide</p>

    <!-- Active post title — updated by JS on switch -->
    <h3 class="sfg-active-title" id={`${uid}-title`}>{matched[0].data.title}</h3>

    <!-- Scrollable content panel: full MDX rendered server-side -->
    <div
      class="sfg-content-panel"
      id={`${uid}-panel`}
      tabindex="0"
      role="region"
      aria-label="Post content"
    >
      {rendered.map(({ Content }, i) => (
        <div
          class={`sfg-post-body blog-prose${i === 0 ? ' is-active' : ''}`}
          data-post-index={i}
          aria-hidden={i > 0 ? 'true' : 'false'}
        >
          <Content />
        </div>
      ))}
    </div>

    <!-- Post switcher list — shown when there are multiple posts -->
    {matched.length > 1 && (
      <div class="sfg-related" role="list">
        <div class="sfg-break" aria-hidden="true"></div>
        {matched.map((post, i) => (
          <div role="listitem">
            {i > 0 && <div class="sfg-row-divider" aria-hidden="true"></div>}
            <button
              class={`sfg-row${i === 0 ? ' is-active' : ''}`}
              type="button"
              data-post-index={i}
              data-post-title={post.data.title}
              data-sfg-uid={uid}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span class="sfg-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="sfg-row-title">{post.data.title}</span>
            </button>
          </div>
        ))}
      </div>
    )}

  </div>
</section>

<div class="sfg-hairline" aria-hidden="true"></div>

<style>
  /* Gold hairlines bracket the section */
  .sfg-hairline {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(201, 169, 97, 0.3) 30%,
      rgba(201, 169, 97, 0.3) 70%,
      transparent
    );
  }

  /* Section: dark navy surround */
  .sfg-section {
    background-color: var(--color-bay-navy);
    padding: 2rem 1.5rem;
  }

  /* Paper card — floats on the dark navy */
  .sfg-card {
    margin: 0 auto;
    max-width: 45rem;
    padding: 3rem 3.5rem;
    background-color: var(--color-bay-paper);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 4px;
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.35);
  }

  /* Eyebrow label */
  .sfg-eyebrow {
    font-family: var(--font-ui, 'Manrope', sans-serif);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(201, 169, 97, 0.7);
    margin-bottom: 1rem;
  }

  /* Active post heading */
  .sfg-active-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--color-bay-ink);
    line-height: 1.25;
    letter-spacing: 0.01em;
    margin-bottom: 1.25rem;
    transition: color 200ms ease;
  }

  /* ── Scrollable content panel ──────────────────────────────── */
  .sfg-content-panel {
    max-height: 360px;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 2px;
    margin-bottom: 2rem;

    /* Thin gold scrollbar */
    scrollbar-width: thin;
    scrollbar-color: rgba(201, 169, 97, 0.35) transparent;
  }

  .sfg-content-panel::-webkit-scrollbar {
    width: 3px;
  }
  .sfg-content-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .sfg-content-panel::-webkit-scrollbar-thumb {
    background: rgba(201, 169, 97, 0.4);
    border-radius: 2px;
  }

  /* Fade hints at top/bottom to signal scrollability */
  .sfg-content-panel::before,
  .sfg-content-panel::after {
    content: '';
    display: block;
    position: sticky;
    left: 0;
    right: 0;
    height: 20px;
    pointer-events: none;
    z-index: 1;
  }
  .sfg-content-panel::before {
    top: 0;
    background: linear-gradient(to bottom, rgba(248,244,237,0.9), transparent);
    margin-bottom: -20px;
  }
  .sfg-content-panel::after {
    bottom: 0;
    background: linear-gradient(to top, rgba(248,244,237,0.9), transparent);
    margin-top: -20px;
  }

  /* ── Post bodies: only .is-active is shown ─────────────────── */
  .sfg-post-body {
    display: none;
    font-size: 0.875rem;
    line-height: 1.75;
  }

  .sfg-post-body.is-active {
    display: block;
  }

  /* Suppress drop-cap in the compact panel */
  .sfg-post-body :global(p:first-of-type::first-letter) {
    float: none;
    font-size: inherit;
    line-height: inherit;
    margin: 0;
    font-weight: inherit;
  }

  /* ── Visual break between panel and post list ──────────────── */
  .sfg-break {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 0, 0, 0.08) 20%,
      rgba(0, 0, 0, 0.08) 80%,
      transparent
    );
    margin-bottom: 1rem;
  }

  /* ── Post switcher rows ────────────────────────────────────── */
  .sfg-row {
    appearance: none;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    width: 100%;
    text-align: left;
    min-height: 3.25rem;
    padding: 0 0.25rem;
    cursor: pointer;
    border-radius: 2px;
    transition: background-color 150ms ease;
  }
  .sfg-row:hover {
    background-color: rgba(201, 169, 97, 0.06);
  }
  .sfg-row:focus-visible {
    outline: 2px solid var(--color-bay-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Active row gets gold accent */
  .sfg-row.is-active .sfg-num,
  .sfg-row.is-active .sfg-row-title {
    color: var(--color-bay-gold);
  }

  /* Row number */
  .sfg-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 13px;
    color: rgba(201, 169, 97, 0.55);
    width: 2.25rem;
    flex-shrink: 0;
    transition: color 150ms ease;
  }
  .sfg-row:hover .sfg-num {
    color: var(--color-bay-gold);
  }

  /* Row title */
  .sfg-row-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: rgba(26, 20, 16, 0.8);
    line-height: 1.4;
    transition: color 150ms ease;
  }
  .sfg-row:hover .sfg-row-title {
    color: var(--color-bay-ink);
  }

  /* Hairline between rows */
  .sfg-row-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 0, 0, 0.07) 20%,
      rgba(0, 0, 0, 0.07) 80%,
      transparent
    );
  }

  /* ── Mobile ─────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .sfg-card {
      padding: 2rem 1.5rem;
    }
    .sfg-active-title {
      font-size: 1.0625rem;
    }
    .sfg-content-panel {
      max-height: 300px;
    }
    .sfg-row {
      min-height: 2.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sfg-row,
    .sfg-num,
    .sfg-row-title,
    .sfg-active-title { transition: none; }
  }
</style>

<script>
  // Post switcher: clicking a row swaps the visible content body and updates the heading.
  document.querySelectorAll<HTMLButtonElement>('button[data-sfg-uid][data-post-index]').forEach(btn => {
    btn.addEventListener('click', () => {
      const uid = btn.dataset.sfgUid!;
      const targetIndex = parseInt(btn.dataset.postIndex!);
      const newTitle = btn.dataset.postTitle!;

      const card = document.querySelector<HTMLElement>(`[data-sfg-uid="${uid}"].sfg-card`);
      if (!card) return;

      // Update heading
      const titleEl = document.getElementById(`${uid}-title`);
      if (titleEl) titleEl.textContent = newTitle;

      // Switch post body visibility
      card.querySelectorAll<HTMLElement>('.sfg-post-body').forEach((el, i) => {
        const active = i === targetIndex;
        el.classList.toggle('is-active', active);
        el.setAttribute('aria-hidden', active ? 'false' : 'true');
      });

      // Update button pressed states
      card.querySelectorAll<HTMLButtonElement>('button[data-post-index]').forEach((b, i) => {
        b.classList.toggle('is-active', i === targetIndex);
        b.setAttribute('aria-pressed', i === targetIndex ? 'true' : 'false');
      });

      // Scroll panel to top for the newly selected post
      const panel = document.getElementById(`${uid}-panel`);
      if (panel) panel.scrollTop = 0;
    });
  });
</script>
