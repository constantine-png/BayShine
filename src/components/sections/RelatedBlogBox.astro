---
// RelatedBlogBox: teaser card linking to Field Guide posts matching a service topic.
import { getCollection } from 'astro:content';

interface Props {
  topic: string;
}

const { topic } = Astro.props;

const all = await getCollection('blog');
const matched = all
  .filter(p => p.data.serviceTopic === topic && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

if (matched.length === 0) return;

const featured = matched[0];
const related = matched.slice(1, 4); // max 3

function excerpt(text: string): string {
  return text.length <= 140 ? text : text.slice(0, 137) + '…';
}
---

<div class="sfg-hairline" aria-hidden="true"></div>

<section class="sfg-section" aria-label="From the Field Guide">
  <div class="sfg-card noise-overlay">

    <p class="sfg-eyebrow">From the Field Guide</p>

    <h3 class="sfg-title">
      <a href={`/blog/${featured.slug}`} class="sfg-title-link">
        {featured.data.title}
      </a>
    </h3>
    <p class="sfg-excerpt">{excerpt(featured.data.description)}</p>
    <a href={`/blog/${featured.slug}`} class="sfg-readmore">
      Read the full entry &rarr;
    </a>

    {related.length > 0 && (
      <div class="sfg-related" role="list">
        <div class="sfg-break" aria-hidden="true"></div>
        {related.map((post, i) => (
          <div role="listitem">
            {i > 0 && <div class="sfg-row-divider" aria-hidden="true"></div>}
            <a href={`/blog/${post.slug}`} class="sfg-row">
              <span class="sfg-num" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="sfg-row-title">{post.data.title}</span>
            </a>
          </div>
        ))}
      </div>
    )}

  </div>
</section>

<div class="sfg-hairline" aria-hidden="true"></div>

<style>
  /* Gold hairlines bracket the section */
  .sfg-hairline {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(201, 169, 97, 0.3) 30%,
      rgba(201, 169, 97, 0.3) 70%,
      transparent
    );
  }

  /* Section: dark navy surround, same as the page */
  .sfg-section {
    background-color: var(--color-bay-navy);
    padding: 2rem 1.5rem;
  }

  /* Paper card — floats on the dark navy */
  .sfg-card {
    margin: 0 auto;
    max-width: 45rem;
    padding: 4rem 3.5rem;
    background-color: var(--color-bay-paper);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 4px;
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.35);
  }

  /* Eyebrow label */
  .sfg-eyebrow {
    font-family: var(--font-ui, 'Manrope', sans-serif);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(201, 169, 97, 0.7);
    margin-bottom: 2rem;
  }

  /* Featured title — links to full post */
  .sfg-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.375rem; /* 22px */
    color: var(--color-bay-ink);
    line-height: 1.25;
    letter-spacing: 0.01em;
    margin-bottom: 0.75rem;
  }

  .sfg-title-link {
    color: inherit;
    text-decoration: none;
  }
  .sfg-title-link:hover {
    color: var(--color-bay-navy);
  }
  .sfg-title-link:focus-visible {
    outline: 2px solid var(--color-bay-gold);
    outline-offset: 3px;
    border-radius: 1px;
  }

  /* Excerpt */
  .sfg-excerpt {
    font-size: 0.9375rem; /* 15px */
    color: rgba(26, 20, 16, 0.75);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  /* Read more link */
  .sfg-readmore {
    display: inline-block;
    font-family: var(--font-ui, 'Manrope', sans-serif);
    font-weight: 500;
    font-size: 13px;
    color: var(--color-bay-gold);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    margin-bottom: 3rem;
  }
  .sfg-readmore:hover {
    text-decoration-thickness: 2px;
  }
  .sfg-readmore:focus-visible {
    outline: 2px solid var(--color-bay-gold);
    outline-offset: 3px;
    border-radius: 1px;
  }

  /* Visual break between featured and related list */
  .sfg-break {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 0, 0, 0.08) 20%,
      rgba(0, 0, 0, 0.08) 80%,
      transparent
    );
    margin-bottom: 1rem;
  }

  /* Related row */
  .sfg-row {
    display: flex;
    align-items: center;
    gap: 0;
    min-height: 3.5rem; /* 56px */
    padding: 0 0.25rem;
    text-decoration: none;
    border-radius: 2px;
    transition: background-color 150ms ease;
  }
  .sfg-row:hover {
    background-color: rgba(201, 169, 97, 0.04);
  }
  .sfg-row:focus-visible {
    outline: 2px solid var(--color-bay-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Row number */
  .sfg-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 13px;
    color: rgba(201, 169, 97, 0.6);
    width: 2.25rem; /* 36px */
    flex-shrink: 0;
    transition: color 150ms ease;
  }
  .sfg-row:hover .sfg-num {
    color: var(--color-bay-gold);
  }

  /* Row title */
  .sfg-row-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: rgba(26, 20, 16, 0.85);
    line-height: 1.4;
    transition: color 150ms ease;
  }
  .sfg-row:hover .sfg-row-title {
    color: var(--color-bay-ink);
  }

  /* Hairline between related rows */
  .sfg-row-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 0, 0, 0.08) 20%,
      rgba(0, 0, 0, 0.08) 80%,
      transparent
    );
  }

  /* Mobile */
  @media (max-width: 640px) {
    .sfg-card {
      padding: 2.5rem 1.75rem;
    }
    .sfg-title {
      font-size: 1.125rem; /* 18px */
    }
    .sfg-row {
      min-height: 3rem; /* 48px */
    }
    .sfg-num {
      width: 1.75rem; /* 28px */
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sfg-row,
    .sfg-num,
    .sfg-row-title { transition: none; }
  }
</style>
