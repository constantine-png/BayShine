---
// CustomerTypeStack — three vertically-stacked customer-segment panels with dark backgrounds.
// Each panel reads as a separate card separated by a gap. No transparent bleed-through.
import Button from '@/components/ui/Button.astro';
---

<section class="customer-type-stack py-4 px-4">
  <div class="container mx-auto max-w-3xl flex flex-col gap-3">

    <!-- Block 1: Private Owners -->
    <div class="customer-panel section-bevel reveal" style="background-color: var(--color-bay-navy);">
      <p class="customer-eyebrow">Private Owners</p>
      <h2 class="customer-headline">Your daily driver.<br />Done right.</h2>
      <p class="customer-body">
        Panel by panel, in correct sequence, on your schedule. The Standing Detail
        program keeps your vehicle in maintained condition year-round.
      </p>
      <Button href="/full-detail" variant="secondary">Full Detail &rarr;</Button>
    </div>

    <!-- Block 2: Fleet & B2B -->
    <div class="customer-panel section-bevel reveal" style="background-color: var(--color-bay-deep);">
      <p class="customer-eyebrow">Fleet &amp; B2B</p>
      <h2 class="customer-headline">Per-unit pricing.<br />Standing schedule.</h2>
      <p class="customer-body">
        Lot maintenance for 30 to 300+ vehicles. Walk the lot, set the schedule,
        receive a monthly invoice. Throughput is the metric.
      </p>
      <Button href="/fleet" variant="secondary">Fleet Programs &rarr;</Button>
    </div>

    <!-- Block 3: Property Programs -->
    <div class="customer-panel section-bevel reveal" style="background-color: rgba(10,18,32,0.85);">
      <p class="customer-eyebrow">Property Programs</p>
      <h2 class="customer-headline">On-property.<br />No overhead.</h2>
      <p class="customer-body">
        Resident detailing program for apartment communities. Residents enroll
        directly: the property adds a premium amenity at zero cost.
      </p>
      <Button href="/apartments" variant="secondary">On-Property Programs &rarr;</Button>
    </div>

  </div>
</section>

<style>
  .customer-panel {
    padding: 72px 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 60vh;
    max-width: 100%;
  }

  .customer-eyebrow {
    color: var(--color-bay-gold);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .customer-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.875rem, 5vw, 2.25rem);
    color: var(--color-bay-white);
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .customer-body {
    color: var(--color-bay-slate);
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 32rem;
  }
</style>
