---
// Sticky bottom bar on mobile only. Phone + Book Now.
// Hidden on md+ where the header handles this.
---
<div
  class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-bay-deep/95 backdrop-blur-sm border-t border-bay-slate/20 py-3 px-4"
  aria-label="Quick actions"
>
  <div class="flex items-center gap-3 max-w-sm mx-auto">
    <a
      href="tel:+18133245522"
      class="flex-1 flex items-center justify-center gap-2 border border-bay-gold/50 text-bay-gold font-semibold text-sm py-2.5 rounded-sm hover:bg-bay-gold/5 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold"
      aria-label="Call BayShine Detailing"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.14 13.5 19.79 19.79 0 0 1 1.07 4.9 2 2 0 0 1 3.05 2.74h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 18z"/>
      </svg>
      Call
    </a>
    <a
      href="/contact"
      class="btn-sweep gloss-cap flex-1 flex items-center justify-center gap-2 bg-bay-gold text-bay-navy font-display font-semibold text-sm py-2.5 rounded-sm hover:bg-[#d9bc79] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold focus-visible:ring-offset-2 focus-visible:ring-offset-bay-deep"
    >
      Book Now
    </a>
  </div>
</div>
