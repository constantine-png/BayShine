---
import { SERVICE_AREA, getCounty } from '@/data/serviceArea';
import Divider from '@/components/ui/Divider.astro';

const pascoZips = SERVICE_AREA.filter(z => getCounty(z.code) === 'Pasco');
const hillsZips = SERVICE_AREA.filter(z => getCounty(z.code) === 'Hillsborough');
---
<footer class="relative noise-overlay bg-bay-navy mt-16 border-t border-bay-slate/15 pt-20 pb-24 md:pb-12">
  <!-- 70% navy overlay — ambient video shows through underneath -->
  <div class="absolute inset-0 bg-bay-navy/70 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 container mx-auto px-4">

    <!-- Large wordmark + tagline -->
    <div class="mb-14">
      <a
        href="/"
        class="inline-block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold rounded-sm"
        aria-label="BayShine Detailing, home"
      >
        <img src="/assets/logo/bayshine_logo_vector.png" alt="BayShine Detailing" width="200" height="67" class="h-12 w-auto mb-6 opacity-90" />
      </a>
      <p class="text-bay-slate text-sm max-w-xs">
        Mobile auto detailing. Pasco County and North Hillsborough, FL.
      </p>
      <a
        href="tel:+18133245522"
        class="mt-3 inline-block text-bay-gold font-semibold text-sm hover:text-[#d9bc79] transition-colors font-mono"
      >
        (813) 324-5522
      </a>
    </div>

    <!-- 5-column nav grid -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10 mb-12">

      <!-- Services -->
      <div>
        <h3 class="text-bay-bone text-xs font-semibold uppercase tracking-widest mb-4">Services</h3>
        <ul class="space-y-2 text-sm text-bay-slate">
          {[
            ['Full Detail', '/full-detail'],
            ['Exterior Detail', '/exterior-detail'],
            ['Ceramic Coating', '/ceramic-coating'],
            ['Heavy Recon', '/recon'],
          ].map(([label, href]) => (
            <li><a href={href} class="hover:text-bay-bone transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Programs -->
      <div>
        <h3 class="text-bay-bone text-xs font-semibold uppercase tracking-widest mb-4">Programs</h3>
        <ul class="space-y-2 text-sm text-bay-slate">
          {[
            ['Standing Detail', '/standing-detail'],
            ['Fleet Programs', '/fleet'],
            ['Apartments', '/apartments'],
            ['Lot Maintenance', '/lot-maintenance'],
          ].map(([label, href]) => (
            <li><a href={href} class="hover:text-bay-bone transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-bay-bone text-xs font-semibold uppercase tracking-widest mb-4">Company</h3>
        <ul class="space-y-2 text-sm text-bay-slate">
          {[
            ['About', '/about'],
            ['Field Notes', '/blog'],
            ['Tools', '/tools'],
          ].map(([label, href]) => (
            <li><a href={href} class="hover:text-bay-bone transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Field Guide -->
      <div>
        <h3 class="text-bay-bone text-xs font-semibold uppercase tracking-widest mb-4">Field Guide</h3>
        <ul class="space-y-2 text-sm text-bay-slate">
          {[
            ['Browse Scenarios', '/field-guide'],
            ['Paint', '/field-guide'],
            ['Interior', '/field-guide'],
          ].map(([label, href]) => (
            <li><a href={href} class="hover:text-bay-bone transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Help -->
      <div>
        <h3 class="text-bay-bone text-xs font-semibold uppercase tracking-widest mb-4">Help</h3>
        <ul class="space-y-2 text-sm text-bay-slate">
          {[
            ['Service Area', '/service-area'],
            ['Get a Quote', '/quote'],
            ['Contact', '/contact'],
          ].map(([label, href]) => (
            <li><a href={href} class="hover:text-bay-bone transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <Divider class="mb-8" />

    <!-- Crawlable zip list — priority zips link to dedicated pages -->
    <div class="mb-8">
      <h3 class="text-bay-bone text-xs font-semibold uppercase tracking-widest mb-4">Service Area</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <p class="text-bay-slate text-xs font-medium uppercase tracking-wider mb-2">Pasco County</p>
          <p class="text-bay-slate text-xs leading-loose">
            {pascoZips.map((z, i) => (
              <>
                {i > 0 && <span class="text-bay-slate/40"> · </span>}
                {z.priority === 'high'
                  ? <a href={`/service-area/${z.code}`} class="hover:text-bay-bone transition-colors">{z.city} ({z.code})</a>
                  : <span>{z.city} ({z.code})</span>
                }
              </>
            ))}
          </p>
        </div>
        <div>
          <p class="text-bay-slate text-xs font-medium uppercase tracking-wider mb-2">North Hillsborough County</p>
          <p class="text-bay-slate text-xs leading-loose">
            {hillsZips.map((z, i) => (
              <>
                {i > 0 && <span class="text-bay-slate/40"> · </span>}
                {z.priority === 'high'
                  ? <a href={`/service-area/${z.code}`} class="hover:text-bay-bone transition-colors">{z.city} ({z.code})</a>
                  : <span>{z.city} ({z.code})</span>
                }
              </>
            ))}
          </p>
        </div>
      </div>
    </div>

    <Divider class="mb-6" />

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-bay-slate text-xs">
      <p>© {new Date().getFullYear()} BayShine Detailing. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a
          href="https://www.instagram.com/bayshine.autoandmarine"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="BayShine on Instagram"
          class="text-bay-slate hover:text-bay-gold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold rounded-sm"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=61582206895679"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="BayShine on Facebook"
          class="text-bay-slate hover:text-bay-gold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bay-gold rounded-sm"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>
