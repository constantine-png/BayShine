---
// Service grid card. Icon, one-line outcome, link. No price.
import type { Service } from '@/data/services';

interface Props {
  service: Service;
}

const { service } = Astro.props;

const icons: Record<string, string> = {
  sparkle: `<path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>`,
  layers: `<polygon points="12 2 2 7 12 12 22 7 12 2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><polyline points="2 17 12 22 22 17" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><polyline points="2 12 12 17 22 12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>`,
  wrench: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>`,
  anchor: `<circle cx="12" cy="5" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/><line x1="12" y1="8" x2="12" y2="22" stroke="currentColor" stroke-width="1.5"/><path d="M5 12H2a10 10 0 0 0 20 0h-3" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  truck: `<rect x="1" y="3" width="15" height="13" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
};
---
<a
  href={service.href}
  class="group block gloss-cap section-bevel bg-bay-navy/60 border border-bay-slate/20 rounded-sm p-6 hover:border-bay-gold/40 transition-colors duration-300"
>
  <div class="mb-4 text-bay-gold opacity-80 group-hover:opacity-100 transition-opacity duration-300">
    <svg
      width="28"
      height="28"
      viewBox="0 0 24 24"
      aria-hidden="true"
      class="relative"
    >
      <!-- specular dot on icon -->
      <circle cx="20" cy="4" r="1.5" fill="rgba(255,255,255,0.15)" aria-hidden="true"/>
      <Fragment set:html={icons[service.iconName] ?? icons.sparkle} />
    </svg>
  </div>

  <h3 class="font-display font-semibold text-bay-white text-base mb-1 leading-tight">
    {service.title}
  </h3>

  <p class="text-bay-slate text-sm leading-relaxed mb-4">
    {service.headline}
  </p>

  <span class="text-bay-gold text-sm font-medium group-hover:underline underline-offset-4">
    See details →
  </span>
</a>
