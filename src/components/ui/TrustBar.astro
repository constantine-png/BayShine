---
// Trust signals strip. Only real data. Placeholders marked for Constantine.
// FOLLOWUP: Replace [YEARS] and [RATING] with actual values when confirmed.
---
<div class="border-y border-bay-slate/20 bg-bay-deep/50 py-4">
  <div class="container mx-auto px-4">
    <ul
      class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-bay-slate"
      aria-label="Trust signals"
    >
      <li class="flex items-center gap-2">
        <span class="relative inline-flex">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-bay-gold" aria-hidden="true">
            <circle cx="20" cy="4" r="1.5" fill="rgba(255,255,255,0.2)"/>
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </span>
        <span>Pasco and North Hillsborough County</span>
      </li>

      <li class="hidden sm:block text-bay-slate/30" aria-hidden="true">·</li>

      <!-- FOLLOWUP: Uncomment and fill when Google reviews are live -->
      <!--
      <li class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-bay-gold" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <span>[RATING] Google Rating</span>
      </li>
      -->

      <li class="flex items-center gap-2">
        <span class="relative inline-flex">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-bay-gold" aria-hidden="true">
            <circle cx="20" cy="4" r="1.5" fill="rgba(255,255,255,0.2)"/>
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </span>
        <span>Mobile · No Drop-Off Required</span>
      </li>
    </ul>
  </div>
</div>
