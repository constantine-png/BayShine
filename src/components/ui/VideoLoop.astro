---
// All <video> elements use this component. Never raw <video> tags.
interface Props {
  src: string;
  ariaLabel: string;
  poster?: string;
  class?: string;
  style?: string;
}
const { src, ariaLabel, poster, class: className = '', style = '' } = Astro.props;
---
<video
  class={className}
  style={style}
  autoplay
  muted
  loop
  playsinline
  preload="metadata"
  aria-label={ariaLabel}
  aria-hidden="true"
  {...(poster ? { poster } : {})}
>
  <source src={src} type="video/mp4" />
</video>

<style>
  @media (prefers-reduced-motion: reduce) {
    video { display: none; }
  }
</style>
